				<Properties>
					<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local UIS = game:GetService("UserInputService")

local FrameAnimator = require(RS.Main.UI.FrameAnimator)
local LeftFX = require(RS.Main.UI.LeftButtonFX)
local ShopCardFX = require(RS.Main.UI.ShopCardFX)
local Audio = require(RS.Main.Controllers.AudioController)

local L = Players.LocalPlayer
local PG = L:WaitForChild("PlayerGui")
local GUI = PG:WaitForChild("Main")

local MENUS: {[string]: { Button: TextButton, Frame: Frame, Backdrop: Frame?, CloseBtn: TextButton? }} = {
	Inventory = {
		Button   = GUI.Left.InventoryButton.TextButton,
		Frame    = GUI.Menus.InventoryFrame,
		Backdrop = GUI.Menus.InventoryFrame:FindFirstChild("Backdrop") :: Frame?,
		CloseBtn = GUI.Menus.InventoryFrame.Main:FindFirstChild("CloseButton") :: TextButton?,
	},
	Backpack = {
		Button   = GUI.Left.BackpackButton.TextButton,
		Frame    = GUI.Menus.BackpackFrame,
		CloseBtn = GUI.Menus.BackpackFrame.Main:FindFirstChild("CloseButton") :: TextButton?,
	},
	Quests = {
		Button   = GUI.Left.QuestsButton.TextButton,
		Frame    = GUI.Menus.QuestsFrame,
		CloseBtn = GUI.Menus.QuestsFrame.Main:FindFirstChild("CloseButton") :: TextButton?,
	},
	Shop = {
		Button   = GUI.Left.ShopButton.TextButton,
		Frame    = GUI.Menus.ShopFrame,
		CloseBtn = GUI.Menus.ShopFrame.Main:FindFirstChild("CloseButton") :: TextButton?,
		Gamepasses = {
			StarterBundle = {
				ScrollingFrame = GUI.Menus.ShopFrame.Main.CanvasGroup.ScrollingFrame.StarterBundleFrame,
				StarterBundleFrame = GUI.Menus.ShopFrame.Main.CanvasGroup.ScrollingFrame.StarterBundleFrame,
				StarterBuy = GUI.Menus.ShopFrame.Main.CanvasGroup.ScrollingFrame.StarterBundleFrame.TextButton
			}
		}
	},
	Settings = {
		Button   = GUI.Left.SettingsButton.TextButton,
		Frame    = GUI.Menus.SettingsFrame,
		CloseBtn = GUI.Menus.SettingsFrame.Main:FindFirstChild("CloseButton") :: TextButton?,
	},
	Upgrades = {
		Button   = GUI.Left.UpgradeButton.TextButton,
		Frame    = GUI.Menus.UpgradesFrame,
		CloseBtn = GUI.Menus.UpgradesFrame.Main:FindFirstChild("CloseButton") :: TextButton?,
	},
	Codes = {
		Button   = GUI.Left.CodesButton.TextButton,
		Frame    = GUI.Menus.CodesFrame,
		CloseBtn = GUI.Menus.CodesFrame.Main:FindFirstChild("CloseButton") :: TextButton?,
	},
}

local openMenu: string? = nil
local busy = false

local RollButton = GUI.Bottom.RollButtonsHolder.RollButton
local QuickRollButton = GUI.Bottom.RollButtonsHolder.QuickRollButton
local AutoRollButton = GUI.Bottom.RollButtonsHolder.AutoRollButton

local SFX_ROOT = RS.Main.Assets.SFX.UI

-- =====================================================
-- Helpers
-- =====================================================
local function isAnyAnimating(): boolean
	for _, cfg in pairs(MENUS) do
		if FrameAnimator.isAnimating(cfg.Frame) then return true end
	end
	return false
end

local function lockInputs(on: boolean)
	busy = on
	for _, cfg in pairs(MENUS) do
		if cfg.Button then
			cfg.Button.Active = not on
			cfg.Button.AutoButtonColor = not on
		end
	end
end

local function buildSfxMap(root: Instance)
	local map = {}
	for _, d in ipairs(root:GetDescendants()) do
		if d:IsA("Sound") then
			map[d.Name] = d.SoundId
		end
	end
	return map
end

local SFX = buildSfxMap(SFX_ROOT)

SFX.UI_Click = SFX.UI_Click or SFX.UIButton or SFX.UI
SFX.UI_Open  = SFX.UI_Open  or SFX.Open     or SFX.UIButton or SFX.UI
SFX.UI_Close = SFX.UI_Close or SFX.Close    or SFX.UIButton or SFX.UI
SFX.UI_Error = SFX.UI_Error or SFX.UIError  or SFX.UI

Audio:Register(SFX)
Audio:Preload({ "UI_Click", "UI_Open", "UI_Close", "UI_Error" })

local function sfx(key: string, opts)
	Audio:SFX(key, opts)
end

local function closeMenu(name: string)
	local cfg = MENUS[name]; if not cfg then return end
	if not cfg.Frame.Visible then return end
	lockInputs(true)
	
	sfx("UI_Close")

	FrameAnimator.closeModal(cfg.Frame, cfg.Backdrop, {
		closeDuration = 0.25,
		closeEasingStyle = Enum.EasingStyle.Quad,
		closeEasingDirection = Enum.EasingDirection.In,
	})

	task.defer(function()
		repeat task.wait() until not isAnyAnimating()
		lockInputs(false)
	end)
	openMenu = nil
end

local function openMenuFn(name: string)
	local cfg = MENUS[name]; if not cfg then return end
	lockInputs(true)

	if openMenu and openMenu ~= name and MENUS[openMenu] then
		FrameAnimator.closeModal(MENUS[openMenu].Frame, MENUS[openMenu].Backdrop, {
			closeDuration = 0.18,
		})
	end
	
	sfx("UI_Open")

	FrameAnimator.openModal(cfg.Frame, cfg.Backdrop, {
		openDuration = 0.5,
		openEasingStyle = Enum.EasingStyle.Back,
		openEasingDirection = Enum.EasingDirection.Out,
	})

	openMenu = name

	task.defer(function()
		repeat task.wait() until not isAnyAnimating()
		lockInputs(false)
	end)
end

local function toggleMenu(name: string)
	if busy or isAnyAnimating() then return end
	if openMenu == name then
		closeMenu(name)
	else
		openMenuFn(name)
	end
end

local function closeAll()
	if openMenu then closeMenu(openMenu) end
end

-- =====================================================
-- Bind buttons
-- =====================================================
-- Left Buttons
LeftFX.attach(GUI.Left.BackpackButton)
LeftFX.attach(GUI.Left.InventoryButton)
LeftFX.attach(GUI.Left.QuestsButton)
LeftFX.attach(GUI.Left.ShopButton)
LeftFX.attach(GUI.Left.SettingsButton)
LeftFX.attach(GUI.Left.UpgradeButton)
LeftFX.attach(GUI.Left.CodesButton)

-- Other Buttons
LeftFX.attach2(RollButton)
LeftFX.attach2(QuickRollButton)
LeftFX.attach2(AutoRollButton)

local shopScroll = GUI.Menus.ShopFrame.Main.CanvasGroup.ScrollingFrame
local shopCleaner = ShopCardFX.AttachAll(shopScroll, {
	onCardClick = function(card)
		print("Preview:", card.Name)
	end,
	onBuyClick = function(card)
		-- TODO: devproduct/gamepass purchase
		print("Buy:", card.Name)
		return true -- mark Owned on success
	end,
	SoundId = "rbxassetid://7149511660",
})

for name, cfg in pairs(MENUS) do
	if cfg.Button then
		sfx("UI_Click")

		cfg.Button.MouseButton1Click:Connect(function()
			if busy then return end
			toggleMenu(name)
		end)
	end

	if cfg.CloseBtn then
		FrameAnimator.wireCloseButton(cfg.CloseBtn, function()
			if busy then return end
			if openMenu == name then closeMenu(name) end
		end)
	end

	FrameAnimator.bindClose(cfg.Frame, function()
		if openMenu == name then closeMenu(name) end
	end, cfg.Backdrop)

	if cfg.Backdrop then
		cfg.Backdrop.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 and openMenu == name then
				sfx("UI_Close")
				closeMenu(name)
			end
		end)
	end
end

UIS.InputBegan:Connect(function(input, gpe)
	if gpe or busy then return end
	if input.KeyCode == Enum.KeyCode.Escape and openMenu then
		sfx("UI_Close")
		closeMenu(openMenu)
	end
end)

-- =====================================================
-- Expose global API (for other LocalScripts)
-- =====================================================
_G.UIManager = {
	Toggle = toggleMenu,
	Open = openMenuFn,
	Close = closeMenu,
	CloseAll = closeAll,
	GetOpen = function() return openMenu end,
	IsBusy = function() return busy end,
}]]></ProtectedString>
