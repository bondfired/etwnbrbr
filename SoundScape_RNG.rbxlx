				</Item>
				<Item class="ModuleScript" referent="RBX7D5F677B6A3A4D37B75FFFA94626CF9E">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Players     = game:GetService("Players")
local RS          = game:GetService("ReplicatedStorage")
local Players 	  = game:GetService("Players")

local GameCore    = require(RS.Main.GameCore)
local DataService = require(RS.Main.Services.DataService)
local ItemsCfg    = require(RS.Main.Configs.Items)
local QuestsCfg   = require(RS.Main.Configs.Quests)

local Svc = {
	Name = "QuestService",
	Routes = {},
	DependsOn = { "DataService" },
}

local onlineLoops: {[number]: boolean} = {}

local function now() return os.time() end

local function ensureState(plr: Player)
	local prof = DataService:Get(plr); if not prof then return end
	local d = prof.Data
	d.Quests = d.Quests or {}
	d.Quests.Daily = d.Quests.Daily or {
		seed = 0,
		refreshAt = 0,
		set = {},
		progress = {},
		claimed = {},
	}
end

local function snapshot(plr: Player)
	local prof = DataService:Get(plr); if not prof then return nil end
	local Q = prof.Data.Quests.Daily
	return {
		filter    = "Daily",
		refreshIn = math.max(0, (Q.refreshAt or 0) - now()),
		set       = Q.set,
		progress  = Q.progress,
		claimed   = Q.claimed,
	}
end

local function repickDailies(plr: Player)
	local prof = DataService:Get(plr); if not prof then return end
	local d = prof.Data
	local Q = d.Quests.Daily

	local pool = QuestsCfg.Pool.Daily or {}
	if #pool == 0 then
		Q.set, Q.progress, Q.claimed = {}, {}, {}
		Q.refreshAt = now() + (QuestsCfg.RefreshSeconds or 86400)
		DataService:MarkDirty(plr)
		return
	end

	local rng = Random.new()
	local bag = table.clone(pool)
	for i = #bag, 2, -1 do
		local j = rng:NextInteger(1, i)
		bag[i], bag[j] = bag[j], bag[i]
	end

	local count = math.clamp(QuestsCfg.DailyCount or 5, 1, #bag)
	Q.set, Q.progress, Q.claimed = {}, {}, {}
	for i = 1, count do
		table.insert(Q.set, bag[i])
		Q.progress[bag[i].id] = 0
	end
	Q.refreshAt = now() + (QuestsCfg.RefreshSeconds or 86400)
	DataService:MarkDirty(plr)
end

local function refreshIfNeeded(plr: Player)
	local prof = DataService:Get(plr); if not prof then return end
	local Q = prof.Data.Quests.Daily
	if (Q.refreshAt or 0) <= now() or not Q.set or #Q.set == 0 then
		repickDailies(plr)
	end
end

local function iterRewards(rewards)
	if not rewards then return function() end end
	if typeof(rewards) == "table" and rewards[1] and rewards[1].id then
		local i = 0
		return function()
			i += 1
			local it = rewards[i]
			if it then return it.id, tonumber(it.amount or 1) or 1 end
		end
	end
	local keys = {}
	for k,_ in pairs(rewards) do table.insert(keys, k) end
	local gi, ai = 0, 0
	return function()
		while true do
			if gi == 0 or not rewards[keys[gi]][ai] then
				gi += 1; ai = 0
				if not keys[gi] then return end
			end
			ai += 1
			local it = rewards[keys[gi]][ai]
			if it then return it.id, tonumber(it.amount or 1) or 1 end
		end
	end
end

function Svc:IncrementMany(plr: Player, bumps: {{key:string, amount:number}})
	for _,b in ipairs(bumps or {}) do
		self:Increment(plr, b.key, b.amount)
	end
end

function Svc:Increment(plr: Player, statKey: string, amount: number)
	local prof = DataService:Get(plr); if not prof then return end
	ensureState(plr); refreshIfNeeded(plr)
	local Q = prof.Data.Quests.Daily

	local changed = {}
	for _, q in ipairs(Q.set) do
		if q.statKey == statKey then
			local newv = math.min((Q.progress[q.id] or 0) + (amount or 0), q.target or math.huge)
			if newv ~= Q.progress[q.id] then
				Q.progress[q.id] = newv
				changed[q.id] = newv
			end
		end
	end
	
	if next(changed) then
		DataService:MarkDirty(plr)
		Svc.Net:Send(plr, "QuestProgressTick", { progress = changed })
	end
end

Svc.Routes.RequestQuests = function(plr: Player)
	ensureState(plr); refreshIfNeeded(plr)
	Svc.Net:Send(plr, "QuestsSnapshot", snapshot(plr))
	return true
end

Svc.Routes.Increment = function(plr: Player, payload)
	if type(payload) ~= "table" then return false, "bad payload" end
	local key = tostring(payload.statKey or "")
	local amt = tonumber(payload.amount or 1) or 1
	if key == "" or amt <= 0 then return false, "bad args" end
	Svc:Increment(plr, key, amt)
	return true
end

Svc.Routes.Claim = function(plr: Player, payload)
	if type(payload) ~= "table" then return false, "bad payload" end
	local qid = tostring(payload.id or "")
	if qid == "" then return false, "no id" end

	ensureState(plr); refreshIfNeeded(plr)

	local prof = DataService:Get(plr); if not prof then return false, "no profile" end
	local Q = prof.Data.Quests.Daily

	local def = nil
	for _, q in ipairs(Q.set) do
		if q.id == qid then def = q; break end
	end
	if not def then return false, "not in set" end

	if Q.claimed[qid] then return false, "already claimed" end
	local prog   = tonumber(Q.progress[qid] or 0) or 0
	local target = tonumber(def.target or 1) or 1
	if prog < target then return false, "incomplete" end

	local granted = {}
	for id, amt in iterRewards(def.rewards) do
		if ItemsCfg[id] and amt > 0 then
			local d = prof.Data
			d.Items = d.Items or {}
			d.Items[id] = (tonumber(d.Items[id]) or 0) + amt
			table.insert(granted, { id = id, amount = amt })
		end
	end

	Q.claimed[qid] = true
	DataService:MarkDirty(plr)

	Svc.Net:Send(plr, "Claimed", { id = qid, rewards = granted })
	Svc.Net:Send(plr, "QuestsSnapshot", snapshot(plr))
	return true
end

function Svc:Start()
	Players.PlayerAdded:Connect(function(plr)
		task.spawn(function()
			if DataService:EnsureLoaded(plr, 15) then
				ensureState(plr); refreshIfNeeded(plr)
				Svc.Net:Send(plr, "QuestsSnapshot", snapshot(plr))

				onlineLoops[plr.UserId] = true
				task.spawn(function()
					while onlineLoops[plr.UserId] and plr.Parent == Players do
						Svc:Increment(plr, "OnlineSeconds", 1)
						task.wait(1)
					end
				end)
			end
		end)
	end)

	Players.PlayerRemoving:Connect(function(plr)
		onlineLoops[plr.UserId] = nil
	end)

	for _, plr in ipairs(Players:GetPlayers()) do
		task.spawn(function()
			if DataService:EnsureLoaded(plr, 15) then
				ensureState(plr); refreshIfNeeded(plr)
				Svc.Net:Send(plr, "QuestsSnapshot", snapshot(plr))
				onlineLoops[plr.UserId] = true
				task.spawn(function()
					while onlineLoops[plr.UserId] and plr.Parent == Players do
						Svc:Increment(plr, "OnlineSeconds", 1)
						task.wait(1)
					end
				end)
			end
		end)
	end
end

return Svc
]]></ProtectedString>
						<string name="ScriptGuid">{72DA7F9D-3B58-426F-BA6D-3C9FBBCFAC66}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">QuestService</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">75ac41b4e7384c7a08dd220d00003c3a</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="RBX107B452FCE3C4CAEBB1A2185208370A3">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Players        = game:GetService("Players")
local RunService     = game:GetService("RunService")
local ServerStorage  = game:GetService("ServerStorage")
local RS             = game:GetService("ReplicatedStorage")
local HttpService    = game:GetService("HttpService")
local PhysicsService = game:GetService("PhysicsService")

local TAU = math.pi * 2

local Cards    = require(RS.Main.Configs.Cards)
local GameCore = require(RS.Main.GameCore)

local Svc = { Name = "CardPetService", Routes = {} }

local CARDS_FOLDER = workspace:FindFirstChild("Cards") or Instance.new("Folder")
CARDS_FOLDER.Name = "Cards"
CARDS_FOLDER.Parent = workspace

local TEMPLATE: BasePart = ServerStorage:WaitForChild("CardTemplate") :: BasePart

local VFX = {
	ByRarity = {},
	Default = function(_part: BasePart) end,
}

local ORBIT = {
	Attack = { BaseRadius=3.5, Height=1.8, Speed=0.30, BobAmplitude=0.20, BobSpeed=0.80, BankAngleDeg=8 },
	Support= { BaseRadius=5.4, Height=2.2, Speed=0.25, BobAmplitude=0.15, BobSpeed=0.70, BankAngleDeg=6 },
}

local PET_GROUP = "CardPets"
pcall(function() PhysicsService:RegisterCollisionGroup(PET_GROUP) end)
PhysicsService:CollisionGroupSetCollidable(PET_GROUP, PET_GROUP, false)

local function prepPart(p: BasePart)
	p.Anchored = true; p.CanCollide = false; p.CanTouch = false; p.CanQuery = false; p.Massless = true
	p.CollisionGroup = PET_GROUP
end

local PACK = {
	RingStep    = 2.4,          -- distance between concentric rings
	VertStep    = 0.15,         -- vertical lift per outer ring
	EffScale    = 1.25,         -- enlarge the card’s effective radius (banking, image bleed)
	MinThetaRad = math.rad(16), -- minimum angular span safeguard (small-n edge cases)
	MaxPerRing  = 6,            -- split into multiple rings if more
	Margin      = 0.45,         -- extra studs added between neighbors
}

type GroupKey = "A" | "S"
type PetInfo = {
	Part: BasePart,
	Player: Player,
	CardId: string,
	Group: GroupKey,
	StartT: number,
	Ring: number,
	IdxOnRing: number,
	Capacity: number,
	BasePhase: number,
	Radius: number,
	EffR: number,
}

local pets: {[Player]: {[GroupKey]: {[string]: PetInfo}}} = {}

local function arrayToString(arr: {string}): string
	return HttpService:JSONEncode(arr)
end
local function stringToArray(str: string?): {string}
	if not str or str == "" then return {} end
	local ok, res = pcall(HttpService.JSONDecode, HttpService, str)
	return ok and res or {}
end
local function safeDestroy(x: Instance?) if x and x.Parent then x:Destroy() end end

local function setCardArt(part: BasePart, imageId: string)
	for _, faceName in ipairs({"Front","Back"}) do
		local gui = part:FindFirstChild(faceName)
		if gui and gui:IsA("SurfaceGui") then
			local fr = gui:FindFirstChild("Frame")
			local img = fr and fr:FindFirstChild("ImageLabel")
			if img and img:IsA("ImageLabel") then img.Image = imageId or "" end
		end
	end
end

local function applyVFX(part: BasePart, cardId: string)
	local cfg = Cards.ById and Cards.ById[cardId]
	local rarity = cfg and cfg.rarity or nil
	local fn = (rarity and VFX.ByRarity[rarity]) or VFX.Default
	if fn then pcall(fn, part) end
end

local function ensureBuckets(plr: Player)
	pets[plr] = pets[plr] or { A = {}, S = {} }
end

local function cleanupPet(plr: Player, cardId: string?, role: GroupKey?)
	local bucket = pets[plr]; if not bucket then return end
	local function kill(map)
		if not map then return end
		if cardId then
			local info = map[cardId]
			if info then safeDestroy(info.Part); map[cardId] = nil end
		else
			for _, info in pairs(map) do safeDestroy(info.Part) end
			for k in pairs(map) do map[k] = nil end
		end
	end
	if role then kill(bucket[role]) else kill(bucket.A); kill(bucket.S) end
end

local function effectiveRadius(part: BasePart): number
	local x, z = part.Size.X, part.Size.Z
	local diag = math.sqrt(x*x + z*z)
	return 0.5 * diag * PACK.EffScale
end

local function snakeOrder(eff: {number}): {number}
	table.sort(eff, function(a,b) return a>b end)
	local i, j = 1, #eff
	local out = {}
	while i <= j do
		table.insert(out, eff[i]); i += 1
		if i <= j then table.insert(out, eff[j]); j -= 1 end
	end
	return out
end

local function solveRadiusForEqualStep(r: {number}, baseR: number): number
	local n = #r
	if n <= 1 then
		return math.max(baseR, (r[1] or 0) + PACK.Margin)
	end
	local s = math.sin(math.pi / n)
	local need = 0
	for i=1,n do
		local a = r[i]
		local b = r[(i % n) + 1]
		need = math.max(need, (a + b + PACK.Margin) / (2 * math.max(s, 1e-6)))
	end
	for i=1,n do need = math.max(need, r[i] + PACK.Margin*0.5) end
	return math.max(baseR, need)
end

local function packEqualAngle(plr: Player, g: GroupKey)
	local bucket = pets[plr] and pets[plr][g]; if not bucket then return end

	local items = {}
	for _, info in pairs(bucket) do
		if info.Part and info.Part.Parent then
			info.EffR = effectiveRadius(info.Part)
			table.insert(items, info)
		end
	end
	if #items == 0 then return end

	table.sort(items, function(a,b) return a.EffR > b.EffR end)

	local style = (g == "A") and ORBIT.Attack or ORBIT.Support
	local ring = 0
	local idx = 1
	while idx <= #items do
		local last = math.min(idx + PACK.MaxPerRing - 1, #items)
		local group = {}
		for k=idx,last do table.insert(group, items[k]) end

		local effList = {}
		for _,info in ipairs(group) do table.insert(effList, info.EffR) end
		effList = snakeOrder(effList)

		local baseR = style.BaseRadius + ring * PACK.RingStep
		local R = solveRadiusForEqualStep(effList, baseR)

		local n = #group
		local step = TAU / n
		for i, info in ipairs(group) do
			info.Ring = ring
			info.Capacity = n
			info.IdxOnRing = i-1
			info.Radius = R
			info.BasePhase = (i-1) * step
		end

		idx = last + 1
		ring += 1
	end
end

local function repack(plr: Player)
	packEqualAngle(plr, "A")
	packEqualAngle(plr, "S")
end

local function forceRepack(plr: Player)
	task.defer(function()
		repack(plr)
		task.wait(0.03)
		repack(plr)
	end)
end

local function makePet(plr: Player, cardId: string, role: GroupKey)
	local chr = plr.Character
	local root = chr and chr:FindFirstChild("HumanoidRootPart") :: BasePart?
	if not (root and root.Parent) then return end
	ensureBuckets(plr)
	if pets[plr][role][cardId] then return end

	local cfg = Cards.ById and Cards.ById[cardId]
	local image = (cfg and cfg.image) or ""

	local pet: BasePart = TEMPLATE:Clone()
	pet.Name = string.format("%s_%s_%sPet", plr.Name, role == "A" and "Atk" or "Sup", cardId)
	pet.CFrame = root.CFrame
	pet.Parent = CARDS_FOLDER
	prepPart(pet)

	setCardArt(pet, image)
	applyVFX(pet, cardId)

	local info: PetInfo = {
		Part = pet, Player = plr, CardId = cardId, Group = role,
		StartT = os.clock(),
		Ring = 0, IdxOnRing = 0, Capacity = 1, BasePhase = 0,
		Radius = (role == "A" and ORBIT.Attack.BaseRadius or ORBIT.Support.BaseRadius),
		EffR = effectiveRadius(pet),
	}
	pets[plr][role][cardId] = info
end


local function normRole(role: any): GroupKey
	local s = tostring(role or "Attack"):lower()
	return (s == "support" or s == "s") and "S" or "A"
end

local function readEquips(plr: Player)
	local atk = stringToArray(plr:GetAttribute("EquippedAttacks"))
	local sup = stringToArray(plr:GetAttribute("EquippedSupports"))
	if #atk == 0 and #sup == 0 then
		local legacy = stringToArray(plr:GetAttribute("EquippedCards"))
		if #legacy > 0 then atk = legacy end
	end
	return atk, sup
end
local function writeEquips(plr: Player, atk: {string}, sup: {string})
	plr:SetAttribute("EquippedAttacks", arrayToString(atk))
	plr:SetAttribute("EquippedSupports", arrayToString(sup))
end

Svc.Routes.Equip = function(plr: Player, payload)
	local id = payload and payload.id
	if type(id) ~= "string" or id == "" then return false, "bad id" end
	if not (Cards.ById and Cards.ById[id]) then return false, "unknown card" end
	local role = normRole(payload and payload.role)

	local atk, sup = readEquips(plr)
	local list = (role == "A") and atk or sup
	if not table.find(list, id) then
		table.insert(list, id)
		writeEquips(plr, atk, sup)
		makePet(plr, id, role)
		forceRepack(plr)
	end
	return true
end

Svc.Routes.Unequip = function(plr: Player, payload)
	local id = payload and payload.id
	local role = payload and payload.role and normRole(payload.role) or nil
	local atk, sup = readEquips(plr)

	local function remove(lst: {string})
		if not id then return {} end
		local i = table.find(lst, id); if i then table.remove(lst, i) end
		return lst
	end

	if id then
		if role == "A" then atk = remove(atk); cleanupPet(plr, id, "A")
		elseif role == "S" then sup = remove(sup); cleanupPet(plr, id, "S")
		else atk = remove(atk); sup = remove(sup); cleanupPet(plr, id, "A"); cleanupPet(plr, id, "S") end
	else
		atk = {}; sup = {}; cleanupPet(plr)
	end

	writeEquips(plr, atk, sup)
	forceRepack(plr)
	return true
end

Svc.Routes.Refresh = function(plr: Player, _payload)
	cleanupPet(plr)
	local atk, sup = readEquips(plr)
	for _, id in ipairs(atk) do if id ~= "" then makePet(plr, id, "A") end end
	for _, id in ipairs(sup) do if id ~= "" then makePet(plr, id, "S") end end
	repack(plr)
	return true
end

local function hookCharacter(plr: Player, _char: Model)
	task.defer(function()
		local atk, sup = readEquips(plr)
		for _, id in ipairs(atk) do if id ~= "" then makePet(plr, id, "A") end end
		for _, id in ipairs(sup) do if id ~= "" then makePet(plr, id, "S") end end
		repack(plr)
	end)
end

Players.PlayerAdded:Connect(function(plr)
	plr.CharacterAdded:Connect(function(char) hookCharacter(plr, char) end)
	plr.CharacterRemoving:Connect(function() cleanupPet(plr) end)
end)

for _, plr in ipairs(Players:GetPlayers()) do
	plr.CharacterAdded:Connect(function(char) hookCharacter(plr, char) end)
	plr.CharacterRemoving:Connect(function() cleanupPet(plr) end)
end

RunService.Heartbeat:Connect(function()
	local now = os.clock()
	for plr, groups in pairs(pets) do
		local chr = plr.Character
		local root = chr and (chr:FindFirstChild("HumanoidRootPart") or chr.PrimaryPart)
		if root and root:IsDescendantOf(workspace) then
			for role, map in pairs(groups) do
				local style = (role == "A") and ORBIT.Attack or ORBIT.Support
				for id, info in pairs(map) do
					local part = info.Part
					if part and part.Parent then
						local ang = (now - info.StartT) * style.Speed * TAU + info.BasePhase
						local bob = math.sin(now * style.BobSpeed * TAU + info.IdxOnRing) * style.BobAmplitude
						local y = style.Height + bob + (info.Ring * PACK.VertStep)
						local pos = (root.CFrame * CFrame.new(
							math.cos(ang) * info.Radius,
							y,
							math.sin(ang) * info.Radius
							)).Position
						local look = CFrame.lookAt(pos, root.Position, Vector3.yAxis)
						local bank = CFrame.Angles(0, 0, math.rad(style.BankAngleDeg) * math.sin(ang))
						part.CFrame = look * bank
					else
						map[id] = nil
					end
				end
			end
		end
	end
end)

return Svc
]]></ProtectedString>
						<string name="ScriptGuid">{4E6811AF-DCE5-4A25-AF45-1A3D38E5F426}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">CardPetService</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">0b98b47d8e24a46108dfb1a700002cc1</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="RBX8FC71FB40C144645A0EF49E0A564D4B6">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local RS      = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

local GameCore    = require(RS.Main.GameCore)
local DataService = require(RS.Main.Services.DataService)
local UpgCfg      = require(RS.Main.Configs.Upgrades)
local AdminCfg    = require(RS.Main.Configs.Admin)

local Svc = { Name = "UpgradeService", Routes = { RequestStatus = true, RequestUpgrade = true, AdminSetPoints = true } }

local PER_POINT = tonumber(UpgCfg.PointsPerRolls) or 500
local function rollsToNextPoint(totalRolls: number)
	if PER_POINT <= 0 then return 0 end
	local rem = totalRolls % PER_POINT
	return (rem == 0) and PER_POINT or (PER_POINT - rem)
end

local function isAdmin(plr: Player): boolean
	if AdminCfg.IsAdmin then return AdminCfg.IsAdmin(plr.UserId, plr.Name) end
	return false
end

local function ensure(plr)
	local d = DataService:GetData(plr)
	if not d then
		return { Levels = {}, Points = 0, RollsDone = 0, PointsSpent = 0, BonusPoints = 0 }, nil
	end
	d.Upgrades = d.Upgrades or { Levels = {}, Points = 0, RollsDone = 0, PointsSpent = 0, BonusPoints = 0 }
	d.Upgrades.Levels      = d.Upgrades.Levels or {}
	d.Upgrades.Points      = d.Upgrades.Points or 0
	d.Upgrades.RollsDone   = d.Upgrades.RollsDone or 0
	d.Upgrades.PointsSpent = d.Upgrades.PointsSpent or 0
	d.Upgrades.BonusPoints = d.Upgrades.BonusPoints or 0
	return d.Upgrades, d
end

local function snapshotPayload(plr)
	local u, d = ensure(plr)
	local rolls   = tonumber(d and d.Rolls or 0) or 0
	local gained  = (PER_POINT > 0) and math.floor(rolls / PER_POINT) or 0
	local spent   = tonumber(u.PointsSpent or 0) or 0
	local bonus   = tonumber(u.BonusPoints or 0) or 0
	u.Points      = math.max(0, (gained + bonus) - spent)
	return {
		points      = u.Points,
		rollsToNext = rollsToNextPoint(rolls),
		levels      = u.Levels,
	}
end

local function sendSnapshot(plr)
	if not DataService:WaitLoaded(plr, 10) then return end
	Svc.Net:Send(plr, "UpgradesSnapshot", snapshotPayload(plr))
end

local function findPlayerByName(name: string): Player?
	name = tostring(name or "")
	if name == "" then return nil end
	for _, p in ipairs(Players:GetPlayers()) do
		if string.lower(p.Name) == string.lower(name) then return p end
	end
	return nil
end

Svc.Routes.RequestStatus = function(plr)
	sendSnapshot(plr)
	return true
end

Svc.Routes.RequestUpgrade = function(plr, payload)
	if not DataService:WaitLoaded(plr, 5) then return false, "data not loaded" end
	local u, d = ensure(plr); if not d then return false, "no profile" end
	local id  = tostring(payload.id or "")
	local amt = math.max(1, tonumber(payload.times or payload.amount or 1) or 1)
	local cfg = UpgCfg.Upgrades[id]; if not cfg then return false, "bad upgrade" end

	u.Levels[id] = u.Levels[id] or 0
	local cur = u.Levels[id]
	if cur >= (cfg.maxLevel or 0) then return false, "maxed" end

	local rolls  = tonumber(d.Rolls or 0) or 0
	local gained = (PER_POINT > 0) and math.floor(rolls / PER_POINT) or 0
	local spent  = tonumber(u.PointsSpent or 0) or 0
	local bonus  = tonumber(u.BonusPoints or 0) or 0
	u.Points     = math.max(0, (gained + bonus) - spent)

	local can = math.min(amt, u.Points, (cfg.maxLevel or 0) - cur)
	if can <= 0 then return false, "no points" end

	u.Points      = u.Points - can
	u.Levels[id]  = cur + can
	u.PointsSpent = spent + can

	DataService:MarkDirty(plr)
	Svc.Net:Send(plr, "Upgraded", {
		id          = id,
		level       = u.Levels[id],
		points      = snapshotPayload(plr).points,
		rollsToNext = snapshotPayload(plr).rollsToNext,
	})
	sendSnapshot(plr)
	return true
end

Svc.Routes.AdminSetPoints = function(_plr, payload)
	if not isAdmin(_plr) then return false, "no permission" end
	if type(payload) ~= "table" then return false, "bad payload" end
	local targetName = tostring(payload.target or "")
	local desired    = tonumber(payload.points)
	if targetName == "" or not desired or desired < 0 then return false, "bad args" end

	local target = findPlayerByName(targetName)
	if not target then return false, "player not found" end
	if not DataService:EnsureLoaded(target, 10) then return false, "no profile" end

	local u, d = ensure(target); if not d then return false, "no profile" end
	local rolls  = tonumber(d.Rolls or 0) or 0
	local gained = (PER_POINT > 0) and math.floor(rolls / PER_POINT) or 0
	local spent  = tonumber(u.PointsSpent or 0) or 0

	local newBonus = math.max(0, math.floor(desired + spent - gained))
	u.BonusPoints = newBonus
	u.Points      = math.max(0, (gained + newBonus) - spent)

	DataService:MarkDirty(target)
	sendSnapshot(target)
	return true
end

return Svc

]]></ProtectedString>
						<string name="ScriptGuid">{8339C9B2-D5AF-4791-9F02-51B4D0730975}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">UpgradeService</string>
						<int64 name="SourceAssetId">-1</int64>
