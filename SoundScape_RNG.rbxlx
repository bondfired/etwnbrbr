						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local TweenService = game:GetService("TweenService")

local M = {}

local function UIScaleOf(gui: GuiObject)
	local s = gui:FindFirstChildOfClass("UIScale")
	if not s then s = Instance.new("UIScale"); s.Parent = gui end
	return s
end

local function kill(tw)
	if tw and tw.PlaybackState == Enum.PlaybackState.Playing then tw:Cancel() end
end

local function spin(grad: UIGradient?, seconds: number)
	if not grad then return end
	task.spawn(function()
		while grad.Parent do
			grad.Rotation = 0
			local t = TweenService:Create(grad, TweenInfo.new(seconds, Enum.EasingStyle.Linear), {Rotation = 360})
			t:Play(); t.Completed:Wait()
		end
	end)
end

local function bob(gui: GuiObject?)
	if not gui then return end
	task.spawn(function()
		local base = gui.Position
		while gui.Parent do
			local up = TweenService:Create(gui, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Position = base - UDim2.fromOffset(0, 4)})
			local dn = TweenService:Create(gui, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.In),  {Position = base})
			up:Play(); up.Completed:Wait(); dn:Play(); dn.Completed:Wait()
		end
	end)
end

local function pulseText(t: TextLabel?)
	if not t then return end
	task.spawn(function()
		local s = UIScaleOf(t)
		while t.Parent do
			local a = TweenService:Create(s, TweenInfo.new(0.7, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 1.06})
			local b = TweenService:Create(s, TweenInfo.new(0.7, Enum.EasingStyle.Quad, Enum.EasingDirection.In),  {Scale = 1.00})
			a:Play(); a.Completed:Wait(); b:Play(); b.Completed:Wait()
		end
	end)
end

local function hookClickable(container: Instance, clickable: GuiButton, scaleTarget: Instance, strokes: {UIStroke}?, opts)
	local tHover, tLeave, tDown, tUp
	local baseThickness = {}
	for i, s in ipairs(strokes or {}) do baseThickness[i] = s.Thickness end

	clickable.AutoButtonColor = false

	clickable.MouseEnter:Connect(function()
		kill(tLeave); kill(tHover)
		tHover = TweenService:Create(scaleTarget, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 1.06})
		tHover:Play()
		for i, s in ipairs(strokes or {}) do
			TweenService:Create(s, TweenInfo.new(0.12), {Thickness = baseThickness[i] + 1}):Play()
		end
	end)

	local function leave()
		kill(tHover); kill(tLeave)
		tLeave = TweenService:Create(scaleTarget, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 1})
		tLeave:Play()
		for i, s in ipairs(strokes or {}) do
			TweenService:Create(s, TweenInfo.new(0.12), {Thickness = baseThickness[i]}):Play()
		end
	end
	clickable.MouseLeave:Connect(leave)

	clickable.MouseButton1Down:Connect(function()
		kill(tDown)
		tDown = TweenService:Create(scaleTarget, TweenInfo.new(0.06, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 0.96})
		tDown:Play()
	end)

	clickable.MouseButton1Up:Connect(function()
		kill(tUp)
		tUp = TweenService:Create(scaleTarget, TweenInfo.new(0.10, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1.06})
		tUp:Play()
	end)

	local cooling = false
	clickable.Activated:Connect(function()
		if cooling then return end
		cooling = true
		if typeof(opts.onClick) == "function" then
			task.spawn(opts.onClick, container)
		end
		task.delay(opts.clickCooldown or 0.25, function() cooling = false end)
	end)

	if container:IsA("GuiObject") then
		container:GetPropertyChangedSignal("Visible"):Connect(function()
			if not container.Visible then
				if scaleTarget:IsA("UIScale") then scaleTarget.Scale = 1 end
				for i, s in ipairs(strokes or {}) do s.Thickness = baseThickness[i] end
			end
		end)
	end
end

function M.AttachBundle(frame: Frame, opts)
	opts = opts or {}

	local cardScale = UIScaleOf(frame)
	local outerStroke = frame:FindFirstChildOfClass("UIStroke")
	local outerGrad   = frame:FindFirstChildOfClass("UIGradient")
	local cardButton  = frame:FindFirstChildWhichIsA("TextButton")
	local featured    = frame:FindFirstChild("FeaturedText")
	local gamepassTxt = frame:FindFirstChild("GamepassText")
	local iconTop     = frame:FindFirstChild("Icon") :: GuiObject?

	local cg          = frame:FindFirstChild("CanvasGroup")
	local buyButton   = cg and cg:FindFirstChild("BuyButton")
	local buyStroke   = buyButton and buyButton:FindFirstChildOfClass("UIStroke")
	local buyGrad     = buyButton and buyButton:FindFirstChildOfClass("UIGradient")
	local buyIcon     = buyButton and (buyButton:FindFirstChild("Icon") :: GuiObject?)
	local buyClick    = (buyButton and buyButton:FindFirstChildWhichIsA("TextButton")) :: GuiButton

	spin(outerGrad, 3.2)
	spin(buyGrad,   2.4)
	bob(iconTop)
	bob(buyIcon)
	pulseText(featured and featured:FindFirstChildWhichIsA("TextLabel"))
	pulseText(gamepassTxt and gamepassTxt:FindFirstChildWhichIsA("TextLabel"))

	if cardButton then
		hookClickable(frame, cardButton, cardScale, {outerStroke}, {
			clickCooldown = opts.cardCooldown or 0.20,
			onClick       = opts.onCardClick,
		})
	end

	if buyButton and buyClick then
		local buyScale = UIScaleOf(buyButton :: GuiObject)
		hookClickable(buyButton, buyClick, buyScale, {buyStroke}, {
			clickCooldown = opts.buyCooldown or 0.35,
			onClick       = opts.onBuyClick,
		})
	end
end

function M.AttachAll(root: Instance, opts)
	for _, fr in ipairs(root:GetDescendants()) do
		if fr:IsA("Frame") and string.find(fr.Name, "BundleFrame") then
			M.AttachBundle(fr, opts)
		end
	end
end

return M
]]></ProtectedString>
