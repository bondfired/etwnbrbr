			<Item class="Script" referent="RBXA293409168D6436CB278BA8E3BC406AD">
				<Properties>
					<ProtectedString name="Source"><![CDATA[local RS        = game:GetService("ReplicatedStorage")
local Players   = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local GameCore  = require(RS.Main.GameCore)

if game:GetService("RunService"):IsStudio() then
	GameCore.Log.level = "debug"
end

GameCore.Bus:Connect("ac.event", function(ev)
	local who   = tostring(ev.uid or "?")
	local where = string.format("%s.%s", tostring(ev.route or "?"), tostring(ev.method or "?"))
	local why   = string.format("%s%s", tostring(ev.kind or "?"), ev.msg and (":"..tostring(ev.msg)) or "")
	local w     = ev.weight or 1
	local s     = ev.strikes or (GameCore.AC.GetStrikes(ev.uid) or 0)
	print(("[AC] uid=%s where=%s why=%s weight=%s strikes=%s"):format(who, where, why, w, s))
end)

GameCore.Sched.every("ac-snapshot", 30, function()
	local dump = GameCore.Bus:Invoke("ac.dump")
	local hot  = dump and dump.hot or {}
	local strikes = dump and dump.strikes or {}
	local hotJson = HttpService:JSONEncode(hot)
	print("[AC] Hot routes window:", hotJson)
	local n = 0 for _ in pairs(strikes) do n += 1 end
	print(("[AC] Players with strikes: %d"):format(n))
end)

local function trackCharacter(plr, char)
	print(("[AC] Tracking character for %s"):format(plr.Name))
	GameCore.AC.TrackCharacter(plr, char)
end

for _, plr in pairs(Players:GetPlayers()) do
	GameCore.AC.HookPlayer(plr)
	if plr.Character then
		trackCharacter(plr, plr.Character)
	end
	plr.CharacterAdded:Connect(function(char)
		trackCharacter(plr, char)
	end)
end

Players.PlayerAdded:Connect(function(plr)
	GameCore.AC.HookPlayer(plr)
	if plr.Character then
		trackCharacter(plr, plr.Character)
	end
	plr.CharacterAdded:Connect(function(char)
		trackCharacter(plr, char)
	end)
end)

Players.PlayerRemoving:Connect(function(plr)
	GameCore.AC.UnhookPlayer(plr)
end)

game:GetService("Players").PlayerAdded:Connect(function(plr)
	plr.Chatted:Connect(function(msg)
		if msg:lower() == "/stats" then
			local stats = GameCore.AC.Move:GetStats(plr)
			if stats then
				local info = string.format("Violations: %d | Context: %s | Bursts: %d | Avg Speed: %.1f", 
					stats.violations, stats.context, stats.activeBursts, stats.avgSpeed)
				print(("[STATS] %s: %s"):format(plr.Name, info))
			end
		end
	end)
end)]]></ProtectedString>
