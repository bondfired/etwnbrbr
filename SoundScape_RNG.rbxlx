					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[--!strict
local Module = {}
local LocalizationService = game:GetService("LocalizationService")
local RunService = game:GetService("RunService")

local CONTINENT_CODES: {[string]: {string}} = {
	["North America"] = {"US", "CA"},
	["Europe"] = {"GB", "AL", "AD", "AT", "BY", "BE", "BA", "BG", "HR", "CY", "CZ", "DK", "EE", "FI", "FR", "DE", "GI", "GR", "HU", "IS", "IE", "IT", "LV", "LI", "LT", "LU", "MK", "MT", "MD", "MC", "ME", "NL", "NO", "PL", "PT", "RO", "RU", "SM", "RS", "SK", "SI", "ES", "SE", "CH", "UA", "VA", "IM", "GG", "JE", "AX"},
	["South America"] = {"BR", "AR", "BO", "CL", "CO", "EC", "GY", "PY", "PE", "SR", "UY", "VE"},
	["Central Asia"] = {"KZ", "KG", "TJ", "TM", "UZ"},
	["East Asia"] = {"CN", "HK", "JP", "KP", "KR", "MO", "MN", "TW"},
	["South Asia"] = {"AF", "BD", "BT", "IN", "IR", "MV", "NP", "PK", "LK"},
	["Southeast Asia"] = {"BN", "KH", "ID", "LA", "MM", "MY", "PH", "SG", "TH", "TL", "VN"},
	["Africa"] = {"DZ", "AO", "BJ", "BW", "BF", "BI", "CM", "CV", "CF", "TD", "KM", "CG", "CD", "CI", "DJ", "EG", "GQ", "ER", "ET", "GA", "GM", "GH", "GN", "GW", "KE", "LS", "LR", "LY", "MG", "MW", "ML", "MR", "MU", "YT", "MA", "MZ", "NA", "NE", "NG", "RW", "ST", "SN", "SC", "SL", "SO", "ZA", "SS", "SD", "SZ", "TZ", "TG", "TN", "UG", "EH", "ZM", "ZW"},
	["Oceania"] = {"AU", "FJ", "KI", "MH", "FM", "NR", "NZ", "PW", "PG", "WS", "SB", "TO", "TV", "VU"},
	["Antarctica"] = {"AQ"},
}

local CODE_TO_CONTINENT: {[string]: string} = {}
for continent, codes in pairs(CONTINENT_CODES) do
	for _, code in ipairs(codes) do
		CODE_TO_CONTINENT[code] = continent
	end
end

for _, t in pairs(CONTINENT_CODES) do 
	table.freeze(t) 
end
table.freeze(CONTINENT_CODES)
table.freeze(CODE_TO_CONTINENT)

local cache: {[number]: {continent: string, code: string}} = {}

function Module.fromCountryCode(code: string?): string
	if not code or #code < 2 then return "Unknown" end
	local key = string.upper(string.sub(code, 1, 2))
	return CODE_TO_CONTINENT[key] or "Unknown"
end

function Module.fromPlayer(player: Player): (string, string)
	local hit = cache[player.UserId]
	if hit then return hit.continent, hit.code end

	if RunService:IsStudio() then
		local studioCode = "AU"
		local studioContinent = Module.fromCountryCode(studioCode)
		cache[player.UserId] = {continent = studioContinent, code = studioCode}
		return studioContinent, studioCode
	end

	local ok, code = pcall(function()
		return LocalizationService:GetCountryRegionForPlayerAsync(player)
	end)

	local resolvedCode = (ok and code) or ""
	local continent = Module.fromCountryCode(resolvedCode)
	cache[player.UserId] = {continent = continent, code = resolvedCode}
	return continent, resolvedCode
end

function Module.clearCache(userId: number?)
	if userId then
		cache[userId] = nil
	else
		cache = {}
	end
end

function Module.getPlayersByContinent(continent: string): {Player}
	local players = {}
	for _, player in pairs(game.Players:GetPlayers()) do
		local playerContinent = Module.fromPlayer(player)
		if playerContinent == continent then
			table.insert(players, player)
		end
	end
	return players
end

function Module.getContinentStats(): {[string]: number}
	local stats = {}
	for _, player in pairs(game.Players:GetPlayers()) do
		local continent = Module.fromPlayer(player)
		stats[continent] = (stats[continent] or 0) + 1
	end
	return stats
end

function Module.isPlayerInRegions(player: Player, regions: {string}): boolean
	local continent = Module.fromPlayer(player)
	for _, region in ipairs(regions) do
		if continent == region then return true end
	end
	return false
end

function Module.getTimezone(code: string): string
	local timezones = {
		US = "UTC-5", CA = "UTC-5", AU = "UTC+10", GB = "UTC+0",
		JP = "UTC+9", CN = "UTC+8", DE = "UTC+1", FR = "UTC+1",
		BR = "UTC-3", IN = "UTC+5:30", RU = "UTC+3"
	}
	return timezones[code] or "Unknown"
end

return Module]]></ProtectedString>
