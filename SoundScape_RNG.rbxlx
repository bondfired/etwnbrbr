				<Item class="ModuleScript" referent="RBXA4CDF75C8C774AEFBC424BB44F665306">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local GameCore = require(ReplicatedStorage.Main.GameCore)

local svc = { Name = "AudioService" }

svc.Schemas = {
	Routes = {
		PlaySFX = GameCore.Schema.table({
			key = GameCore.Schema.string(200),
			opts = GameCore.Schema.optional(GameCore.Schema.table({
				volume = GameCore.Schema.optional(GameCore.Schema.number(0, 2)),
				pitch  = GameCore.Schema.optional(GameCore.Schema.number(0.1, 4)),
				minInterval = GameCore.Schema.optional(GameCore.Schema.number(0, 5)),
			}))
		}),
		PlayAt = GameCore.Schema.table({
			pos = GameCore.Schema.table({ x=GameCore.Schema.number(-1e6,1e6), y=GameCore.Schema.number(-1e6,1e6), z=GameCore.Schema.number(-1e6,1e6) }),
			id  = GameCore.Schema.string(200),
			opts = GameCore.Schema.optional(GameCore.Schema.table({
				volume=GameCore.Schema.optional(GameCore.Schema.number(0,2)),
				pitch =GameCore.Schema.optional(GameCore.Schema.number(0.1,4)),
				minDist=GameCore.Schema.optional(GameCore.Schema.number(0,5000)),
				maxDist=GameCore.Schema.optional(GameCore.Schema.number(0,5000)),
			}))
		}),
		Music = GameCore.Schema.table({
			key = GameCore.Schema.string(200),
			opts = GameCore.Schema.optional(GameCore.Schema.table({
				volume=GameCore.Schema.optional(GameCore.Schema.number(0,2)),
				fade  =GameCore.Schema.optional(GameCore.Schema.number(0,10))
			}))
		}),
		StopMusic = GameCore.Schema.optional(GameCore.Schema.table({
			fade = GameCore.Schema.optional(GameCore.Schema.number(0,10))
		})),
		SetVolumes = GameCore.Schema.table({
			map = GameCore.Schema.table({
				Master = GameCore.Schema.optional(GameCore.Schema.number(0,1)),
				Music  = GameCore.Schema.optional(GameCore.Schema.number(0,1)),
				SFX    = GameCore.Schema.optional(GameCore.Schema.number(0,1)),
			})
		}),
		Register = GameCore.Schema.table({ map = GameCore.Schema.table({}) }),
		Preload  = GameCore.Schema.table({ list = GameCore.Schema.table({}) }),
	},
}

svc.Routes = {
	PlaySFX = function(player, p)       svc.Net:Broadcast("sfx",   p) return true end,
	PlayAt  = function(player, p)       svc.Net:Broadcast("sfx3d", p) return true end,
	Music   = function(player, p)       svc.Net:Broadcast("music", p) return true end,
	StopMusic = function(player, p)     svc.Net:Broadcast("music_stop", p or {}) return true end,
	SetVolumes = function(player, p)    svc.Net:Broadcast("vols",  p) return true end,
	Register = function(player, p)      svc.Net:Broadcast("register", p) return true end,
	Preload  = function(player, p)      svc.Net:Broadcast("preload",  p) return true end,
}

function svc:Init() end
function svc:Start()
	GameCore.Rate:Set(self.Name, 30, 1.0)
	GameCore.AC.SetPolicy(self.Name, { maxPayload = 2048 })
end

return svc]]></ProtectedString>
						<string name="ScriptGuid">{DA2D82DB-FE1E-4600-BA3E-7E1152A9B55F}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">AudioService</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">10a3f71bc27752c308e649c600001364</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="RBX4EBAEFAB93EA4979B9E43A5DFA563604">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Players   = game:GetService("Players")
local RS        = game:GetService("ReplicatedStorage")

local GameCore        = require(RS.Main.GameCore)
local DataService     = require(RS.Main.Services.DataService)
local BackpackService = require(RS.Main.Services.BackpackService)
local CodesCfg        = require(RS.Main.Configs.Codes)

local Svc = {
	Name = "CodesService",
	Functions = { Redeem = true },
	DependsOn = { "BackpackService", "DataService" },
}

local CodesStore = GameCore.Data.Store("Codes")

local function normalize(s)
	return (tostring(s or ""):gsub("%s+",""):upper())
end

local function parseDuration(spec: string?): number
	if not spec or spec == "" or spec == "never" then return 0 end
	local n, unit = string.match(spec, "^(%d+)([SMDY])$")
	if not n then return 0 end
	n = tonumber(n) or 0
	if unit == "S" then return n
	elseif unit == "M" then return n * 30 * 24 * 60 * 60
	elseif unit == "D" then return n * 24 * 60 * 60
	elseif unit == "Y" then return n * 365 * 24 * 60 * 60
	end
	return 0
end

local function rewardsFrom(cfgRewardTable)
	local out = {}
	for id, amt in pairs(cfgRewardTable or {}) do
		local n = math.max(1, tonumber(amt or 1) or 1)
		table.insert(out, { id = tostring(id), amount = n })
	end
	return out
end

local function grantRewards(plr, cfg)
	for _,it in ipairs(rewardsFrom(cfg.reward)) do
		BackpackService:GiveItem(plr, it.id, it.amount)
	end
end

local function loadGlobalMeta(code: string, cfg)
	local key = "code:"..code
	local row = CodesStore:Get(key, nil) or {}
	row.uses    = tonumber(row.uses    or 0) or 0
	row.startAt = tonumber(row.startAt or 0) or 0

	if row.startAt == 0 then
		row.startAt = os.time()
	end

	local dur = parseDuration(cfg.expiration)
	if dur > 0 then
		row.expireAt = row.startAt + dur
	else
		row.expireAt = 0
	end

	pcall(function() CodesStore:Set(key, row) end)
	return row
end

local function isExpired(row): boolean
	row = row or {}
	local exp = tonumber(row.expireAt or 0) or 0
	return exp > 0 and os.time() > exp
end

local function tryIncrementGlobal(code: string, cfg)
	local key     = "code:"..code
	local maxUses = tonumber(cfg.globalMaxUses or 0) or 0

	local ok, res = pcall(function()
		return CodesStore:Update(key, function(old)
			old = old or {}
			old.uses    = tonumber(old.uses or 0) or 0
			old.startAt = tonumber(old.startAt or 0) or os.time()

			local dur      = parseDuration(cfg.expiration)
			local expireAt = (dur > 0) and (old.startAt + dur) or 0

			if expireAt > 0 and os.time() > expireAt then
				old.expireAt  = expireAt
				old.lastError = "expired"
				return old
			end

			if maxUses > 0 and old.uses >= maxUses then
				old.expireAt  = expireAt
				old.lastError = "maxed"
				return old
			end

			old.uses      = old.uses + 1
			old.expireAt  = expireAt
			old.lastError = nil
			return old
		end)
	end)

	if not ok then
		return false, "ds_error"
	end

	local row = res
	if type(row) ~= "table" then
		row = CodesStore:Get(key, {}) or {}
	end

	if row.lastError == "expired" then return false, "expired" end
	if row.lastError == "maxed"   then return false, "maxed"   end

	return true, {
		uses     = tonumber(row.uses or 0) or 0,
		expireAt = tonumber(row.expireAt or 0) or 0,
		maxUses  = maxUses,
	}
end

Svc.Functions = Svc.Functions or {}
Svc.Functions.Redeem = function(plr, payload)
	local raw  = payload and payload.code
	local code = normalize(raw)
	if code == "" then
		return { success = false, reason = "empty" }
	end

	local cfg = CodesCfg[code]
	if not cfg then
		return { success = false, reason = "invalid" }
	end

	local meta = loadGlobalMeta(code, cfg)
	if isExpired(meta) then
		return { success = false, reason = "expired" }
	end

	local d = DataService:GetData(plr)
	if not d then
		return { success = false, reason = "no_profile" }
	end
	d.CodesUsed = d.CodesUsed or {}
	if d.CodesUsed[code] then
		return { success = false, reason = "used" }
	end

	local ok, infoOrWhy = tryIncrementGlobal(code, cfg)
	if not ok then
		return { success = false, reason = infoOrWhy }
	end

	grantRewards(plr, cfg)
	d.CodesUsed[code] = os.time()
	DataService:MarkDirty(plr)

	local info = infoOrWhy
	return {
		success   = true,
		expireAt  = info.expireAt or meta.expireAt or 0,
		usedCount = info.uses or (meta.uses + 1),
		maxUses   = info.maxUses or 0,
	}
end

function Svc:Init() end
function Svc:Start() end

return Svc
]]></ProtectedString>
