				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[-- GameCore v3 — single-file, Knit-like auto discovery + Built-in AntiCheat
-- Features:
--  • Configure({Roots = {Services = Instance, Controllers = Instance}})
--  • Auto(): scan folders, require modules, lifecycle :Init/:Start
--  • Net routing (per-service), validation + per-player token-bucket rate-limit
--  • RemoteFunction routing (per-service), request/response
--  • DataStore wrapper + per-server TTL cache
--  • LocalBus (BindableEvent/BindableFunction) for same-executor comms
--  • Debounce/Throttle, Guard helpers
--  • Optional: Promise/AsyncTasks, logging, tracing, scheduler, datapipe, outbox
--  • AntiCheat (AC): payload/schema checks, replay/idempotency abuse, flood escalation,
--  • route muting/kick, strike evidence, hot-route auto-hardening, challenge/response,
--  • economy invariants helpers, movement envelope helpers, cross-server cheater signal

local Players            = game:GetService("Players")
local ReplicatedStorage  = game:GetService("ReplicatedStorage")
local RunService         = game:GetService("RunService")
local DataStoreService   = game:GetService("DataStoreService")

local IS_SERVER = RunService:IsServer()

local MemoryStoreService = IS_SERVER and game:GetService("MemoryStoreService") or nil
local MessagingService   = IS_SERVER and game:GetService("MessagingService")   or nil
local HttpService        = game:GetService("HttpService")

local function now() return os.clock() end

local GameCore = {
	Config = { Roots = {} },
	_started = false,
	_ready = false,
	_systems = {},
	_services = {},
	_controllers = {},
	_routes = {},
	_clientSignals = {},
	_cache = {},
	_remotesFolder = nil,
}

-- Async / Promise plumbing
local PromiseMod = nil
local Async = nil

GameCore.Async = {
	Ready = false,
	Defaults = {
		http    = { retries = 3, timeout = 6, backoff = 0.25, factor = 2, maxBackoff = 4, jitter = 0.3 },
		dsGet   = { retries = 5, timeout = 8, backoff = 0.2,  factor = 2, maxBackoff = 5, jitter = 0.25 },
		dsWrite = { retries = 6, timeout = 8, backoff = 0.25, factor = 2, maxBackoff = 6, jitter = 0.25 },
	},
	Semaphores = {},
	Breakers   = {},
}

-- ========== Utils ==========
local function safe(fn)
	local ok, res = pcall(fn)
	if not ok then warn("[GameCore]", res) end
	return ok, res
end

local function cacheSet(k, v, ttl)
	GameCore._cache[k] = { v = v, e = now() + (ttl or 60) }
end
local function cacheGet(k)
	local d = GameCore._cache[k]; if not d then return nil end
	if now() > d.e then GameCore._cache[k] = nil; return nil end
	return d.v
end

local function merge(a, b)
	local t = {}; if a then for k,v in pairs(a) do t[k]=v end end
	if b then for k,v in pairs(b) do t[k]=v end end
	return t
end

function GameCore.CancelToken() return Async and Async.CancellationTokenSource() or nil end

function GameCore.Http(requestFn, opts)
	assert(Async and PromiseMod, "GameCore.Http: Async/Promise not configured")
	local base = GameCore.Async.Defaults.http
	opts = merge(base, opts)
	opts.semaphore = opts.semaphore or GameCore.Async.Semaphores.http
	opts.breaker   = opts.breaker   or GameCore.Async.Breakers.http
	return Async.run(requestFn, opts)
end

-- ========== Logging / Metrics / Tracing ==========
GameCore.Log = {
	level = "info",
	sinks = {
		function(rec)
			local ok, json = pcall(function() return HttpService:JSONEncode(rec.ctx or {}) end)
			print(string.format("[%-5s] %s %s", rec.level, rec.msg, ok and json or "{}"))
		end
	}
}
do
	local order = { trace=1, debug=2, info=3, warn=4, error=5 }
	function GameCore.Log:emit(level, msg, ctx)
		if (order[level] or 5) < (order[self.level] or 3) then return end
		local rec = { t=os.time(), level=level, msg=msg, ctx=ctx }
		for _,sink in ipairs(self.sinks) do pcall(sink, rec) end
	end
	for _,lv in ipairs({"trace","debug","info","warn","error"}) do
		GameCore.Log[lv] = function(self, msg, ctx) self:emit(lv, msg, ctx) end
	end
end

GameCore.MX = { c={}, h={} }
function GameCore.MX.inc(k, by) GameCore.MX.c[k]=(GameCore.MX.c[k] or 0)+(by or 1) end
function GameCore.MX.observe(k, v)
	local b = GameCore.MX.h[k] or {n=0,sum=0,max=0,min=1/0}
	b.n+=1; b.sum+=v; b.max=math.max(b.max,v); b.min=math.min(b.min,v); GameCore.MX.h[k]=b
end

GameCore.Trace = {}
function GameCore.Trace.span(name, ctx, fn)
	local t0 = now()
	local results = { pcall(fn, { name=name, attrs=ctx or {} }) }
	local ok = table.remove(results, 1)
	local dt = now() - t0
	GameCore.MX.observe("trace:"..name, dt)
	GameCore.Log:debug("span "..name, { ok=ok, dt=dt, name=name, attrs=ctx })
	return ok, table.unpack(results)
end

function GameCore.AsyncHandles()
	return GameCore.Async.Semaphores, GameCore.Async.Breakers
end

-- Guards
local Guard = {}
function Guard.Number(n, min, max)
	if typeof(n) ~= "number" or n ~= n then return min end
	return math.clamp(n, min, max)
end
function Guard.Vector3OK(v) return typeof(v) == "Vector3" end
function Guard.DistanceOK(a, b, maxDist) return (a - b).Magnitude <= maxDist end
GameCore.Guard = Guard

-- ========== Schema guards ==========
GameCore.Schema = {}
function GameCore.Schema.number(min,max) return function(v) return typeof(v)=="number" and (min==nil or v>=min) and (max==nil or v<=max) end end
function GameCore.Schema.string(max)     return function(v) return typeof(v)=="string" and (max==nil or #v<=max) end end
function GameCore.Schema.boolean()       return function(v) return typeof(v)=="boolean" end end
function GameCore.Schema.optional(validator) return function(v) return v==nil or validator(v) end end
function GameCore.Schema.table(map)
	return function(v)
		if typeof(v)~="table" then return false end
		for k,check in pairs(map) do if not check(v[k]) then return false end end
		return true
	end
end

-- ========== Flags ==========
GameCore.Flags = { _ = {} }
function GameCore.Flags:Set(name, on) self._[name]=on end
function GameCore.Flags:Is(name) return self._[name]==true end

-- ========== Auth / Roles ==========
GameCore.Auth = { Roles = {} }
function GameCore.Auth:SetRole(uid, role, allowed)
	local m = self.Roles[uid] or {}; m[role] = allowed; self.Roles[uid] = m
end
function GameCore.Auth:Can(uid, role)
	local m = self.Roles[uid]; return m and m[role] == true or false
end

-- ========== Config ==========
function GameCore.Configure(cfg)
	for k,v in pairs(cfg) do GameCore.Config[k] = v end
	if cfg.Promise then PromiseMod = cfg.Promise end
	if cfg.Async   then Async      = cfg.Async   end
	if cfg.AC and cfg.AC.Whitelist then
		GameCore.AC.SetWhitelist(cfg.AC.Whitelist)
	end
	if cfg.AsyncDefaults then
		for k,v in pairs(cfg.AsyncDefaults) do GameCore.Async.Defaults[k] = v end
	end
	local limits = (cfg.AsyncLimits or {})
	local fail   = (cfg.AsyncBreaker or { failThreshold=5, cooldown=15, halfOpen=2 })

	if Async and PromiseMod and not GameCore.Async.Ready then
		Async.configure({ Promise = PromiseMod })
		GameCore.Async.Semaphores.http = Async.createSemaphore(limits.http or 8)
		GameCore.Async.Semaphores.ds   = Async.createSemaphore(limits.datastore or 6)
		GameCore.Async.Breakers.http   = Async.createBreaker(fail)
		GameCore.Async.Breakers.ds     = Async.createBreaker(fail)
		GameCore.Async.Ready = true
	end

	GameCore.Promise = PromiseMod
	if Async then
		GameCore.Async.run         = function(fn, opts) return Async.run(fn, opts) end
		GameCore.Async.withTimeout = function(pr, t)    return Async.withTimeout(pr, t) end
		GameCore.Async.keyed       = function(key, fn, opts) return Async.keyed(key, fn, opts) end
		GameCore.Async.createSemaphore = Async.createSemaphore
		GameCore.Async.createBreaker   = Async.createBreaker
	end
	
	local ac = cfg.AntiCheat
	if typeof(ac) == "table" then
		GameCore.AC.Enabled  = (ac.Enabled ~= false)
		GameCore.AC.Mode     = ac.Mode or "enforce"  -- "monitor" just logs
		GameCore.Log.level   = ac.LogLevel or GameCore.Log.level

		if ac.Network then
			if ac.Network.MaxPayloadBytes then
				GameCore.Net.MaxPayloadBytes = ac.Network.MaxPayloadBytes
				GameCore.AC.Config.maxPayload = ac.Network.MaxPayloadBytes
			end
			if ac.Network.ReplayWindow then
				GameCore.Idem.ttl = tonumber(ac.Network.ReplayWindow) or GameCore.Idem.ttl
			end
			if ac.Network.Rate and ac.Network.Rate.Default then
				GameCore.Rate.Default = {
					calls  = ac.Network.Rate.Default.calls or GameCore.Rate.Default.calls,
					window = ac.Network.Rate.Default.window or GameCore.Rate.Default.window,
				}
			end
			if ac.Network.Rate and ac.Network.Rate.PerRoute then
				for route,pol in pairs(ac.Network.Rate.PerRoute) do
					if typeof(pol) == "table" then
						GameCore.Rate:Set(route, pol.calls or GameCore.Rate.Default.calls, pol.window or GameCore.Rate.Default.window)
					end
				end
			end
		end
		GameCore.AC._movementCfg = ac.Movement or {}
		GameCore.AC._integrityCfg = ac.Integrity or {}
	end
end

-- ========== Scheduler  ==========
GameCore.Sched = { _jobs = {} }
function GameCore.Sched.every(id, seconds, fn)
	GameCore.Sched._jobs[id] = { s = seconds, next = now() + seconds, fn = fn }
end
RunService.Heartbeat:Connect(function()
	local t = now()
	for id,j in pairs(GameCore.Sched._jobs) do
		if t >= j.next then
			j.next = t + j.s
			task.spawn(function()
				local ok, err = pcall(j.fn)
				if not ok then GameCore.Log:error("sched "..id, {err=err}) end
			end)
		end
	end
end)

-- ========== Data (DataStore + Cache + MemoryStore) ==========
GameCore.Mem = {}
GameCore.DataPipe = { _q = {} } -- key -> { patches = {fn, ...} }
GameCore.Outbox = {}

local function _getOutQ()
	if not IS_SERVER then return nil end
	return GameCore.Mem:Queue("gc2:outbox")
end

function GameCore.DataPipe.push(key, patch)
	local row = GameCore.DataPipe._q[key] or { patches = {} }
	table.insert(row.patches, patch); GameCore.DataPipe._q[key] = row
end

function GameCore.Outbox.Enqueue(topic, payload, ttl)
	if not IS_SERVER then return end
	local outQ = _getOutQ(); if not outQ then return end
	local item = { topic=topic, payload=payload, tries=0, id=HttpService:GenerateGUID(false) }
	outQ:Push(item, ttl or 60)
end

local function makeStore(name)
	local ds = DataStoreService:GetDataStore(name)
	assert(Async and PromiseMod, "GameCore.Data: Async/Promise not configured")

	local sem  = GameCore.Async.Semaphores.ds
	local brk  = GameCore.Async.Breakers.ds
	local getD = GameCore.Async.Defaults.dsGet
	local wrD  = GameCore.Async.Defaults.dsWrite

	return {
		Get = function(_, key, default)
			return Async.keyed(("ds:get:%s:%s"):format(name, key), function()
				return ds:GetAsync(key)
			end, merge(getD, {
				semaphore = sem, breaker = brk, timeout = getD.timeout, cacheTTL = 10,
				retryOn = function(_) return true end,
			}))
				:andThen(function(val) return (val ~= nil and val or default) end)
				:catch(function() return default end)
				:expect()
		end,

		Set = function(_, key, value)
			return Async.run(function()
				return ds:SetAsync(key, value)
			end, merge(wrD, { semaphore = sem, breaker = brk, retryOn = function() return true end }))
				:await()
		end,

		Update = function(_, key, fn)
			return Async.run(function()
				return ds:UpdateAsync(key, fn)
			end, merge(wrD, { semaphore = sem, breaker = brk, retryOn = function() return true end }))
				:await()
		end,
	}
end

GameCore.Sched.every("datapipe-flush", 1, function()
	if not game:GetService("RunService"):IsRunning() then return end
	if not next(GameCore.DataPipe._q) then return end
	local store = GameCore.Data.Store("Players")
	for key,row in pairs(GameCore.DataPipe._q) do
		local ok = false
		if Async then
			Async.run(function()
				return DataStoreService:GetDataStore("Players"):UpdateAsync(key, function(old)
					for _,patch in ipairs(row.patches) do old = patch(old or {}) end
					return old
				end)
			end, { retries=5, backoff=0.25, semaphore=GameCore.Async.Semaphores.ds, breaker=GameCore.Async.Breakers.ds })
				:await()
			ok = true
		else
			store:Update(key, function(old)
				for _,patch in ipairs(row.patches) do old = patch(old or {}) end
				return old
			end)
			ok = true
		end
		if ok then GameCore.DataPipe._q[key] = nil end
	end
end)

GameCore.Sched.every("outbox-flush", 2, function()
	if not IS_SERVER or not game:GetService("RunService"):IsRunning() then return end
	local outQ = _getOutQ(); if not outQ then return end
	local items = outQ:Pull(20, 1)
	for _,it in ipairs(items) do
		GameCore.Http(function()
			MessagingService:PublishAsync("gc2:"..it.topic, it.payload)
			return true
		end, { retries=3, timeout=3 })
			:andThen(function()
				GameCore.MX.inc("outbox.ok")
			end)
			:catch(function()
				GameCore.MX.inc("outbox.fail")
				it.tries += 1
				outQ:Push(it, 30)
			end)
			:await()
	end
end)

function GameCore.Mem:Lock(key, ttl)
	if not IS_SERVER then return nil end
	local lock = MemoryStoreService:GetSortedMap("gc2:locks")
	local token = HttpService:GenerateGUID(false)
	local ok = pcall(function() lock:SetAsync(key, token, ttl) end)
	return ok and token or nil
end

function GameCore.Mem:Unlock(key)
	if not IS_SERVER then return end
	local lock = MemoryStoreService:GetSortedMap("gc2:locks")
	pcall(function() lock:RemoveAsync(key) end)
end

function GameCore.Mem:Queue(name: string)
	if not IS_SERVER or RunService:IsStudio() then
		return { Push=function()end, Pull=function() return {} end }
	end

	if not RunService:IsRunning() or game.PlaceId == 0 then
		return { Push=function()end, Pull=function() return {} end }
	end

	local sanitizedName = name:gsub("[^%w_]", "_"):sub(1, 30)
	local ok, q = pcall(function() return MemoryStoreService:GetQueue("gc_" .. sanitizedName, 512) end)
	if not ok or not q then
		return { Push=function()end, Pull=function() return {} end }
	end

	return {
		Push = function(_, item, ttl)
			if not RunService:IsRunning() then return end
			pcall(function() q:AddAsync(item, ttl or 60) end)
		end,
		Pull = function(_, n, wait)
			if not RunService:IsRunning() then return {} end
			local ok2, items = pcall(function() return q:ReadAsync(n or 1, wait or 1) end)
			return ok2 and items or {}
		end
	}
end

GameCore.Data = {
	Store = function(name) return makeStore(name) end,
	Cache = { Set = cacheSet, Get = cacheGet }
}

function GameCore.Data:AttachLeaderstats(p, map)
	local l = Instance.new("Folder"); l.Name="leaderstats"; l.Parent=p
	local d = GameCore.Data.GetPlayer and GameCore.Data:GetPlayer(p.UserId) or {}
	for name, ty in pairs(map) do
		local v = Instance.new(ty); v.Name = name; v.Value = d[name] or 0; v.Parent = l
	end
end

-- ========== Messaging (cross-server) ==========
GameCore.Msg = {}
function GameCore.Msg:Publish(topic, data)
	if not IS_SERVER then return end
	pcall(function() MessagingService:PublishAsync("gc2:"..topic, data) end)
end
function GameCore.Msg:SafePublish(topic, data, opts)
	if not IS_SERVER then return end
	return GameCore.Http(function()
		MessagingService:PublishAsync("gc2:"..topic, data)
		return true
	end, merge({ retries=3, timeout=3 }, opts)):await()
end
function GameCore.Msg:Subscribe(topic, cb)
	if not IS_SERVER then return nil end
	local sub; sub = MessagingService:SubscribeAsync("gc2:"..topic, function(m) cb(m.Data) end)
	return sub
end

-- ========== LocalBus ==========
local LocalBus = {
	_events = {},
	_funcs  = {},
}
function LocalBus:Event(name)
	local ev = self._events[name]
	if ev and ev.Parent then return ev end
	ev = Instance.new("BindableEvent"); ev.Name = name; self._events[name] = ev; return ev
end
function LocalBus:Function(name)
	local fn = self._funcs[name]
	if fn and fn.Parent then return fn end
	fn = Instance.new("BindableFunction"); fn.Name = name; self._funcs[name] = fn; return fn
end
function LocalBus:Fire(name, payload) self:Event(name):Fire(payload) end
function LocalBus:Connect(name, cb) return self:Event(name).Event:Connect(cb) end
function LocalBus:Bind(name, cb) self:Function(name).OnInvoke = cb end
function LocalBus:Invoke(name, payload) return self:Function(name):Invoke(payload) end
GameCore.Bus = LocalBus

GameCore.Bus:Bind("metrics.dump", function()
	return { c = GameCore.MX.c, h = GameCore.MX.h }
end)

-- ========== Net (per-service RemoteEvent/RemoteFunction) ==========
GameCore._mw = {}
function GameCore.UseMiddleware(route, fn)
	GameCore._mw[route] = GameCore._mw[route] or {}
	table.insert(GameCore._mw[route], fn)
end
local function _runMW(route, ctx, leaf)
	local stack = GameCore._mw[route] or {}
	local i = 0
	local function next(c) i += 1; if stack[i] then stack[i](c, next) else leaf(c) end end
	next(ctx)
end

GameCore.Rate = { Default = {calls=20,window=1.0}, PerRoute = {} }
function GameCore.Rate:Set(route, calls, window) self.PerRoute[route] = {calls=calls,window=window or 1.0} end

local _tb = {} -- token bucket: k -> {t=now, tokens=burst}
local function _allow(uid, route)
	local cfg = GameCore.Rate.PerRoute[route] or GameCore.Rate.Default
	local rate, burst = (cfg.calls / (cfg.window or 1.0)), cfg.calls
	local k = uid..":"..route
	local b = _tb[k] or { t = now(), tokens = burst }
	local t = now()
	local add = (t - b.t) * rate
	b.tokens = math.min(burst, b.tokens + add); b.t = t
	if b.tokens >= 1 then b.tokens -= 1; _tb[k] = b; return true end
	_tb[k] = b
	return false
end

GameCore.Net = { MaxPayloadBytes = 8*1024 }
local function _tooBig(p)
	local ok, s = pcall(function() return HttpService:JSONEncode(p) end)
	return ok and #s > GameCore.Net.MaxPayloadBytes
end

GameCore.Breaker = { tripCount = 5, window = 10, cooldown = 15, _ = {} }
local function _cbKey(uid,route) return uid..":"..route end
local function _recordErr(uid,route)
	local b = GameCore.Breaker._[_cbKey(uid,route)] or {t=now(),n=0,untilT=0}
	if now() < b.untilT then GameCore.Breaker._[_cbKey(uid,route)] = b; return end
	if now()-b.t > GameCore.Breaker.window then b.t=now(); b.n=0 end
	b.n+=1
	if b.n>=GameCore.Breaker.tripCount then b.untilT=now()+GameCore.Breaker.cooldown end
	GameCore.Breaker._[_cbKey(uid,route)] = b
end
local function _canPass(uid,route)
	local b = GameCore.Breaker._[_cbKey(uid,route)]
	return not b or now()>=b.untilT
end

GameCore.Idem = { ttl = 10, _ = {} }
local function _idemKey(plr, route, rid) return ("%d:%s:%s"):format(plr.UserId, route, tostring(rid)) end
function GameCore.Idem:Seen(plr, route, rid)
	if not rid then return false end
	local k=_idemKey(plr,route,rid); local e=self._[k]; if e and now()<e then return true end
	self._[k]=now()+self.ttl; return false
end

GameCore.Metrics = { Hits={}, Rejects={}, Latency={} }
local function _bump(t,k) t[k]=(t[k] or 0)+1 end
local function _time(tag, fn)
	local t=now(); local ok,res1,res2 = pcall(fn); local dt=now()-t
	GameCore.Metrics.Latency[tag]=(GameCore.Metrics.Latency[tag] or 0)*0.9+dt*0.1
	return ok,res1,res2
end

local function remotesFolder()
	if GameCore._remotesFolder and GameCore._remotesFolder.Parent then return GameCore._remotesFolder end
	local f

	if typeof(GameCore.Config.RemotesFolder) == "Instance" then
		f = GameCore.Config.RemotesFolder
	else
		if IS_SERVER then
			f = ReplicatedStorage:FindFirstChild("GameCore_Remotes")
			if not f then f = Instance.new("Folder"); f.Name = "GameCore_Remotes"; f.Parent = ReplicatedStorage end
		else
			f = ReplicatedStorage:WaitForChild("GameCore_Remotes", 10)
		end
	end

	GameCore._remotesFolder = f
	return f
end

local function ensureRemote(name)
	local f = remotesFolder()
	local r = f:FindFirstChild(name)
	if r then return r end
	if IS_SERVER then
		r = Instance.new("RemoteEvent"); r.Name = name; r.Parent = f
		return r
	else
		return f:WaitForChild(name, 10)
	end
end

local function ensureFunction(name)
	local f = remotesFolder()
	local rf = f:FindFirstChild(name .. "_fn")
	if rf then return rf end
	if IS_SERVER then
		rf = Instance.new("RemoteFunction"); rf.Name = name .. "_fn"; rf.Parent = f
		return rf
	else
		return f:WaitForChild(name .. "_fn", 10)
	end
end

----------------------------------------------------------------
-- ========== AntiCheat (AC) ==========
----------------------------------------------------------------
GameCore.AC = {
	_events = {},            -- uid -> { {t, route, method, kind, msg, weight}, ... }
	_strikes = {},           -- uid -> number
	_muted = {},             -- uid:route -> untilT
	_policies = {},          -- route -> policy overrides
	_recentCheaters = {},    -- uid -> untilT (from cross-server signals)
	Hot = { window=10, routeStats={} }, -- routeStats[route]={t, nReject, nHit}
	_whitelist = {},
	Config = {
		strikesToWarn = 3,
		strikesToMute = 5,
		strikesToKick = 8,
		strikeDecay   = 0.10,       -- per minute EMA decay
		evidMax       = 40,         -- max evidence entries per player
		maxPayload    = GameCore.Net.MaxPayloadBytes,
		echoTimestampSkew = 6.0,    -- seconds allowed skew for client timestamps
		autoHarden = { threshold=40, shrink=0.6, floor=5 }, -- % reject spike → tighten rate
	},
	Economy = { defs = {} }, -- name -> { min, max, maxDeltaPerSec }
	Move = { trackers = {} }, -- uid -> tracker
	Challenge = { pending = {} }, -- uid -> { token=string, untilT=number }
	_conns =  {},
	_armed = false
}

GameCore.AC.Move = {
	trackers = {},
	Config = {
		smoothingWindow = 5,      -- frames to average
		burstThreshold = 2.5,     -- multiplier for burst tolerance
		burstDuration = 1.0,      -- seconds to allow bursts
		escalationSteps = {       -- gradual escalation
			{ strikes = 3, action = "warn", weight = 0.5 },
			{ strikes = 6, action = "mute", weight = 0.5 },
			{ strikes = 12, action = "kick", weight = 1.0 }
		},
		contextMultipliers = {
			walking = 1.0,
			running = 1.2,
			jumping = 1.8,
		}
	}
}

local function _uid(p) return (typeof(p)=="Instance" and p.UserId) or p end
local function _evKey(uid, route) return uid..":"..route end

function GameCore.AC.Start()
	if GameCore.AC._armed then return end
	GameCore.AC._armed = true

	local cfg = (GameCore.Config and GameCore.Config.AntiCheat) or {}
	GameCore.AC.Config.echoTimestampSkew = (cfg.Network and cfg.Network.ReplayWindow) or GameCore.AC.Config.echoTimestampSkew
	if cfg.Network and cfg.Network.MaxPayloadBytes then
		GameCore.Net.MaxPayloadBytes = cfg.Network.MaxPayloadBytes
		GameCore.AC.Config.maxPayload = cfg.Network.MaxPayloadBytes
	end

	if cfg.LogLevel and GameCore.Log then
		GameCore.Log.level = tostring(cfg.LogLevel)
	end
end


function GameCore.AC.AttachNetGuards()
	local cfg = (GameCore.Config and GameCore.Config.AntiCheat) or {}
	local rate = cfg.Network and cfg.Network.Rate
	if rate then
		if rate.Default then
			GameCore.Rate.Default = { calls = rate.Default.calls or 20, window = rate.Default.window or 1.0 }
		end
		if rate.PerRoute then
			for route, r in pairs(rate.PerRoute) do
				GameCore.Rate:Set(route, r.calls or 10, r.window or 1.0)
			end
		end
	end
end

function GameCore.AC.HookPlayer(plr)
	-- nothing heavy here yet; just a placeholder
end

function GameCore.AC.UnhookPlayer(plr)
	local uid = plr.UserId
	local c = GameCore.AC._conns[uid]
	if c then
		for _,conn in pairs(c) do if typeof(conn)=="RBXScriptConnection" then pcall(function() conn:Disconnect() end) end end
	end
	GameCore.AC._conns[uid] = nil
	GameCore.AC.Move:End(plr)
end

function GameCore.AC.IsWhitelisted(playerOrUid)
	local uid = _uid(playerOrUid)
	return GameCore.AC._whitelist[uid] == true
end

function GameCore.AC.SetWhitelist(listOrMap)
	local set = {}
	if typeof(listOrMap) == "table" then
		local isArray = (#listOrMap > 0)
		if isArray then
			for _,uid in ipairs(listOrMap) do set[uid] = true end
		else
			for uid,flag in pairs(listOrMap) do if flag then set[tonumber(uid) or uid] = true end end
		end
	end
	GameCore.AC._whitelist = set
end

function GameCore.AC.AddToWhitelist(uid) GameCore.AC._whitelist[_uid(uid)] = true end
function GameCore.AC.RemoveFromWhitelist(uid) GameCore.AC._whitelist[_uid(uid)] = nil end

function GameCore.AC.SetPolicy(route, policy) GameCore.AC._policies[route] = policy end
local function _policyFor(route) return merge(GameCore.AC.Config, GameCore.AC._policies[route] or {}) end

local function _evidPush(uid, ev)
	local buf = GameCore.AC._events[uid] or {}
	table.insert(buf, ev)
	if #buf > GameCore.AC.Config.evidMax then table.remove(buf, 1) end
	GameCore.AC._events[uid] = buf
end

local function _strike(uid, weight, why)
	local s = (GameCore.AC._strikes[uid] or 0)
	s += (weight or 1)
	GameCore.AC._strikes[uid] = s
	GameCore.MX.inc("ac.strike")
	GameCore.Log:warn("AC strike", {uid=uid, by=weight or 1, why=why, total=s})
	return s
end

local function _mute(uid, route, seconds)
	local key = _evKey(uid, route)
	GameCore.AC._muted[key] = now() + (seconds or 10)
	GameCore.Log:warn("AC mute route", {uid=uid, route=route, sec=seconds or 10})
end

local function _isMuted(uid, route)
  if GameCore.AC.IsWhitelisted(uid) then return false end
  local t = GameCore.AC._muted[_evKey(uid, route)]
  return t and now() < t
end

local function _humanoidFromChar(char)
	if not char then return nil end
	local ok, hum = pcall(function() return char:FindFirstChildOfClass("Humanoid") end)
	return ok and hum or nil
end

local function getMovementContext(humanoid)
	if not humanoid then return "walking", 1.0 end

	local state = humanoid:GetState()
	local jumpHeight = humanoid.JumpHeight or 0

	if state == Enum.HumanoidStateType.Jumping or 
		state == Enum.HumanoidStateType.Freefall or
		jumpHeight > 0 then
		return "jumping", GameCore.AC.Move.Config.contextMultipliers.jumping
	elseif humanoid.WalkSpeed > 20 then
		return "running", GameCore.AC.Move.Config.contextMultipliers.running
	else
		return "walking", GameCore.AC.Move.Config.contextMultipliers.walking
	end
end

local function smoothedSpeed(tracker, newSpeed)
	table.insert(tracker.speedHistory, newSpeed)
	if #tracker.speedHistory > GameCore.AC.Move.Config.smoothingWindow then
		table.remove(tracker.speedHistory, 1)
	end

	local sum = 0
	for _, speed in ipairs(tracker.speedHistory) do
		sum = sum + speed
	end
	return sum / #tracker.speedHistory
end

local function checkBurstTolerance(tracker, speed, maxSpeed)
	local now = os.clock()
	local burstLimit = maxSpeed * GameCore.AC.Move.Config.burstThreshold

	local validBursts = {}
	for _, burst in ipairs(tracker.bursts or {}) do
		if now - burst.time < GameCore.AC.Move.Config.burstDuration then
			table.insert(validBursts, burst)
		end
	end
	tracker.bursts = validBursts

	if speed > maxSpeed then
		if speed <= burstLimit and #tracker.bursts < 3 then
			table.insert(tracker.bursts, { time = now, speed = speed })
			return true, "burst_allowed"
		else
			return false, "burst_exceeded"
		end
	end

	return true, "normal"
end

local function getEscalationAction(player, violations)
	local cfg = GameCore.AC.Move.Config.escalationSteps

	for i = #cfg, 1, -1 do
		local step = cfg[i]
		if violations >= step.strikes then
			return step.action, step.weight
		end
	end

	return "log", 0.1
end

local originalTrackCharacter = GameCore.AC.TrackCharacter

function GameCore.AC.TrackCharacter(plr, char)
	local uid = plr.UserId

	if originalTrackCharacter then
		originalTrackCharacter(plr, char)
	end

	local cfg = (GameCore.Config and GameCore.Config.AntiCheat) or {}
	local mv = cfg.Movement or {}

	local hum = char:FindFirstChildOfClass("Humanoid")
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hum or not hrp then return end

	local base = tonumber(mv.BaseWalkSpeed or 16)
	local sprint = tonumber(mv.MaxSprintSpeed or 50)
	local tol = tonumber(mv.SpeedTolerance or 15)
	local maxWS = math.max(base, sprint) + tol

	GameCore.AC.Move:Begin(plr, { 
		maxSpeed = maxWS, 
		maxTeleport = tonumber(mv.MaxTP or 100) 
	})

	local conns = GameCore.AC._conns[uid] or {}
	if conns.hb then
		conns.hb:Disconnect()
	end

	conns.hb = game:GetService("RunService").Heartbeat:Connect(function()
		if not hrp.Parent then return end
		GameCore.AC.Move:Update(plr, hrp.Position, hum)
	end)

	GameCore.AC._conns[uid] = conns
end

GameCore.Sched.every("ac-decay", 60, function()
	for uid, s in pairs(GameCore.AC._strikes) do
		local dec = s * GameCore.AC.Config.strikeDecay
		local ns = math.max(0, s - dec)
		GameCore.AC._strikes[uid] = ns
	end
end)

if IS_SERVER then
	GameCore.Msg:Subscribe("ac.flag", function(data)
		local uid = data and data.uid
		if uid then GameCore.AC._recentCheaters[uid] = now() + 300 end
	end)
end

local function _flagCrossServer(uid, reason)
	if not IS_SERVER then return end
	GameCore.Msg:Publish("ac.flag", { uid = uid, reason = reason, t = os.time() })
end

-- Public API
function GameCore.AC.Report(player, route, method, kind, msg, weight)
	local uid     = _uid(player)
	local pol     = _policyFor(route)
	local cfg     = (GameCore.Config and GameCore.Config.AntiCheat) or {}
	local mode    = (cfg.Mode or "enforce") -- "enforce" | "monitor"
	local isStaff = GameCore.AC.IsWhitelisted(uid)

	local w  = (weight ~= nil) and weight or 1
	local ev = { t = now(), uid = uid, route = route, method = method, kind = kind, msg = msg, weight = isStaff and 0 or w }

	_evidPush(uid, ev)

	local total = GameCore.AC._strikes[uid] or 0
	if not isStaff then
		total = _strike(uid, w, (kind or "ac") .. ":" .. (msg or ""))
	end
	ev.strikes = total

	GameCore.Bus:Fire("ac.event", ev)

	local function logAt(level, text)
		if GameCore.Log and GameCore.Log[level] then
			GameCore.Log[level](GameCore.Log, text, ev)
		end
	end

	if isStaff then
		logAt("debug", "AC staff event")
		return total
	end

	if mode == "monitor" then
		logAt("info", "AC monitor")
		return total
	end

	if total >= (pol.strikesToKick or 8) then
		logAt("error", "AC kick")
		_flagCrossServer(uid, kind)
		if typeof(player) == "Instance" and player.Kick then
			task.defer(function()
				pcall(function() player:Kick("Security: integrity checks failed.") end)
			end)
		end
	elseif total >= (pol.strikesToMute or 5) then
		logAt("warn", "AC mute")
		_mute(uid, route, 15)
	elseif total >= (pol.strikesToWarn or 3) then
		logAt("warn", "AC warn")
	else
		logAt("info", "AC strike")
	end

	return total
end

function GameCore.AC.GetStrikes(player) return GameCore.AC._strikes[_uid(player)] or 0 end
function GameCore.AC.GetEvidence(player) return GameCore.AC._events[_uid(player)] or {} end

GameCore.Bus:Bind("ac.dump", function()
	return {
		strikes = GameCore.AC._strikes,
		recent  = GameCore.AC._events,
		hot     = GameCore.AC.Hot.routeStats
	}
end)

function GameCore.AC.Economy:Register(name, cfg)
	GameCore.AC.Economy.defs[name] = cfg or {}
end
function GameCore.AC.Economy:Validate(uid, resourceName, newValue, lastValue, dt, context)
	local d = GameCore.AC.Economy.defs[resourceName]
	if not d then return true end
	if d.min and newValue < d.min then
		GameCore.AC.Report(uid, "Economy", "Set", "econ:min", resourceName, 2); return false
	end
	if d.max and newValue > d.max then
		GameCore.AC.Report(uid, "Economy", "Set", "econ:max", resourceName, 2); return false
	end
	if d.maxDeltaPerSec and lastValue ~= nil and dt and dt>0 then
		local delta = math.abs(newValue - lastValue) / dt
		if delta > d.maxDeltaPerSec then
			GameCore.AC.Report(uid, "Economy", "Set", "econ:delta", resourceName, 2); return false
		end
	end
	return true
end

function GameCore.AC.Move:Begin(player, opts)
	local uid = typeof(player) == "Instance" and player.UserId or player
	local config = opts or {}

	self.trackers[uid] = {
		lastPos = nil,
		lastT = nil,
		maxSpeed = config.maxSpeed or 35,
		maxTeleport = config.maxTeleport or 100,
		speedHistory = {},
		violations = 0,
		lastViolation = 0,
		bursts = {},
		context = "walking",
		contextMultiplier = 1.0
	}
end

function GameCore.AC.Move:Update(player, pos, humanoid)
	local uid = typeof(player) == "Instance" and player.UserId or player
	local tracker = self.trackers[uid]
	if not tracker then return true end

	local now = os.clock()

	local context, multiplier = getMovementContext(humanoid)
	tracker.context = context
	tracker.contextMultiplier = multiplier

	if tracker.lastPos and tracker.lastT then
		local dt = math.max(1e-3, now - tracker.lastT)
		local dist = (pos - tracker.lastPos).Magnitude
		local rawSpeed = dist / dt

		local contextMaxSpeed = tracker.maxSpeed * multiplier

		if dist > tracker.maxTeleport then
			GameCore.AC.Report(player, "Move", "Update", "teleport", 
				string.format("dist=%.2f context=%s", dist, context), 3)
			tracker.lastPos, tracker.lastT = pos, now
			return false
		end

		local smoothSpeed = smoothedSpeed(tracker, rawSpeed)

		local burstOK, burstReason = checkBurstTolerance(tracker, rawSpeed, contextMaxSpeed)

		if rawSpeed > contextMaxSpeed and smoothSpeed > contextMaxSpeed and not burstOK then
			tracker.violations = tracker.violations + 1

			if now - tracker.lastViolation > 30 then
				tracker.violations = math.max(0, tracker.violations - 1)
			end
			tracker.lastViolation = now

			local action, weight = getEscalationAction(player, tracker.violations)

			local msg = string.format("raw=%.1f smooth=%.1f max=%.1f ctx=%s burst=%s", 
				rawSpeed, smoothSpeed, contextMaxSpeed, context, burstReason)

			if action == "warn" then
				GameCore.AC.Report(player, "Move", "Update", "speed_warn", msg, weight)
			elseif action == "mute" then
				GameCore.AC.Report(player, "Move", "Update", "speed_mute", msg, weight)
			elseif action == "kick" then
				GameCore.AC.Report(player, "Move", "Update", "speed_kick", msg, weight)
			else
				GameCore.Log:info("Speed anomaly", {
					uid = uid,
					rawSpeed = rawSpeed,
					smoothSpeed = smoothSpeed,
					maxSpeed = contextMaxSpeed,
					context = context,
					violations = tracker.violations
				})
			end
		end
	end

	tracker.lastPos, tracker.lastT = pos, now
	return true
end

function GameCore.AC.Move:End(player)
	local uid = typeof(player) == "Instance" and player.UserId or player
	self.trackers[uid] = nil
end

function GameCore.AC.Move:GetStats(player)
	local uid = typeof(player) == "Instance" and player.UserId or player
	local tracker = self.trackers[uid]
	if not tracker then return nil end

	return {
		violations = tracker.violations,
		context = tracker.context,
		activeBursts = #tracker.bursts,
		avgSpeed = #tracker.speedHistory > 0 and 
			(table.concat(tracker.speedHistory, "+") / #tracker.speedHistory) or 0
	}
end

function GameCore.AC.Challenge:Issue(player, ttl)
	if not IS_SERVER then return nil end
	local uid = _uid(player)
	local tok = HttpService:GenerateGUID(false)
	GameCore.AC.Challenge.pending[uid] = { token = tok, untilT = now() + (ttl or 5) }
	return tok
end
function GameCore.AC.Challenge:Verify(player, token)
	local uid = _uid(player)
	local row = GameCore.AC.Challenge.pending[uid]
	if not row or now() > row.untilT then
		GameCore.AC.Report(player, "AC", "Challenge", "challenge:timeout", "", 2)
		return false
	end
	if token ~= row.token then
		GameCore.AC.Report(player, "AC", "Challenge", "challenge:mismatch", "", 3)
		return false
	end
	GameCore.AC.Challenge.pending[uid] = nil
	return true
end

local function _hotUpdate(route, hit, reject)
	local R = GameCore.AC.Hot.routeStats[route] or { t = now(), nReject = 0, nHit = 0 }
	if hit    then R.nHit    += 1 end
	if reject then R.nReject += 1 end
	if now() - R.t >= GameCore.AC.Hot.window then
		local rej = R.nReject; local tot = math.max(1, R.nHit + R.nReject)
		local pct = (rej / tot) * 100
		local cfg = GameCore.AC.Config.autoHarden
		if pct >= cfg.threshold then
			local cur = GameCore.Rate.PerRoute[route] or GameCore.Rate.Default
			local calls = math.max(cfg.floor, math.floor((cur.calls or 20) * (cfg.shrink or 0.6)))
			GameCore.Rate:Set(route, calls, cur.window or 1.0)
			GameCore.Log:warn("AC auto-harden", {route=route, rejectPct=math.floor(pct), calls=calls})
		end
		R.t, R.nReject, R.nHit = now(), 0, 0
	end
	GameCore.AC.Hot.routeStats[route] = R
end

----------------------------------------------------------------
-- AC Middleware (runs on every route/function call)
----------------------------------------------------------------
local function _validateSchema(svc, methodMapName, method, payload)
	local schemasTbl = rawget(svc, "Schemas")
	if not schemasTbl then return true end
	local map = rawget(schemasTbl, methodMapName) 
	if not map then return true end
	local validator = map[method]
	if typeof(validator) == "function" then
		local succ = false
		local okpc = pcall(function() succ = validator(payload) end)
		if not okpc or succ ~= true then return false, "schema" end
	end
	return true
end

local function _acNetGuard(kind, svcName, svcObj, player, method, payload)
	payload = payload or {}
	local uid = player and player.UserId or 0
	local pol = _policyFor(svcName .. (kind=="fn" and "_fn" or ""))
	local isStaff = GameCore.AC.IsWhitelisted(uid)
	
	local okSize, encoded = pcall(function() return HttpService:JSONEncode(payload) end)
	if okSize and encoded and #encoded > (pol.maxPayload or GameCore.Net.MaxPayloadBytes) then
		if not isStaff then
			GameCore.AC.Report(player, svcName, method, "payload", "too_big", 2)
		end
		_hotUpdate(svcName .. (kind=="fn" and "_fn" or ""), false, true)
		return false, "payload_too_big"
	end

	if isStaff then
		return true
	end

	local rc = GameCore.AC._recentCheaters[uid]
	if rc and now() < rc then
		_strike(uid, 0.5, "recent-flag")
	end

	if _isMuted(uid, svcName .. (kind=="fn" and "_fn" or "")) then
		GameCore.MX.inc("ac.muted.hit")
		_hotUpdate(svcName .. (kind=="fn" and "_fn" or ""), false, true)
		return false, "muted"
	end

	local okSize, encoded = pcall(function() return HttpService:JSONEncode(payload) end)
	if okSize and encoded and #encoded > (pol.maxPayload or GameCore.Net.MaxPayloadBytes) then
		GameCore.AC.Report(player, svcName, method, "payload", "too_big", 2)
		_hotUpdate(svcName .. (kind=="fn" and "_fn" or ""), false, true)
		return false, "payload_too_big"
	end

	if typeof(payload)=="table" and payload.ts then
		local skew = math.abs((tonumber(payload.ts) or now()) - now())
		if skew > (pol.echoTimestampSkew or 6.0) then
			GameCore.AC.Report(player, svcName, method, "clock", ("skew=%.2f"):format(skew), 1)
		end
	end

	local mapName = (kind=="fn") and "Functions" or "Routes"
	local okSchema = _validateSchema(svcObj, mapName, method, payload)
	if not okSchema then
		GameCore.AC.Report(player, svcName, method, "schema", "invalid_payload", 2)
		_hotUpdate(svcName .. (kind=="fn" and "_fn" or ""), false, true)
		return false, "schema"
	end

	return true
end

local _origBindRoute = nil
local _origBindFunction = nil

local bindRoute
local bindFunction

----------------------------------------------------------------
-- Server route create (RemoteEvent, method dispatch)
----------------------------------------------------------------
local function _baseBindRoute(name, schema)
	local re = ensureRemote(name)
	GameCore._routes[name] = schema
	re.OnServerEvent:Connect(function(player, method, payload)
		if typeof(method) ~= "string" then return end

		if _tooBig(payload) then _bump(GameCore.Metrics.Rejects, name); _hotUpdate(name, false, true); return end

		if not _allow(player.UserId, name) then
			_bump(GameCore.Metrics.Rejects, name); _hotUpdate(name, false, true)
			GameCore.AC.Report(player, name, method, "flood", "rate_limit", 1)
			return
		end
		if not _canPass(player.UserId, name) then
			_bump(GameCore.Metrics.Rejects, name); _hotUpdate(name, false, true); return
		end
		if GameCore.Idem:Seen(player, name, payload and payload.rid) then
			_bump(GameCore.Metrics.Rejects, name); _hotUpdate(name, false, true)
			GameCore.AC.Report(player, name, method, "replay", "idem_seen", 1)
			return
		end

		local fn = schema[method]; if typeof(fn) ~= "function" then return end
		_bump(GameCore.Metrics.Hits, name); _hotUpdate(name, true, false)

		_runMW(name, {player=player,method=method,payload=payload}, function(ctx)
			local ok,res1,res2 = GameCore.Trace.span("route:"..name.."."..method, {uid=player.UserId}, function()
				GameCore.MX.observe("fn:"..name, GameCore.Metrics.Latency[name.."_fn"] or 0)
				return _time(name, function() return fn(ctx.player, ctx.payload) end)
			end)
			if not ok then
				local err = tostring(res1)
				GameCore.Log:error("route error", {route=name, method=method, err=err})
				_recordErr(player.UserId, name); _bump(GameCore.Metrics.Rejects, name); _hotUpdate(name, false, true)
			else
				local success, msg = res1, res2
				if not success and msg then
					GameCore.Log:warn("route reject", {route=name, method=method, msg=msg})
				end
			end
		end)
	end)
	return {
		Send = function(_, plr, method, payload) re:FireClient(plr, method, payload) end,
		Broadcast = function(_, method, payload) re:FireAllClients(method, payload) end,
	}
end

----------------------------------------------------------------
-- Server function router (RemoteFunction, method dispatch)
----------------------------------------------------------------
local function _baseBindFunction(name, schema)
	local rf = ensureFunction(name)
	rf.OnServerInvoke = function(player, method, payload)
		if typeof(method) ~= "string" then return nil end

		if _tooBig(payload) then _bump(GameCore.Metrics.Rejects, name.."_fn"); _hotUpdate(name.."_fn", false, true); return nil end
		if not _allow(player.UserId, name.."_fn") then
			_bump(GameCore.Metrics.Rejects, name.."_fn"); _hotUpdate(name.."_fn", false, true)
			GameCore.AC.Report(player, name, method, "flood", "rate_limit", 1)
			return nil
		end
		if not _canPass(player.UserId, name.."_fn") then _bump(GameCore.Metrics.Rejects, name.."_fn"); _hotUpdate(name.."_fn", false, true); return nil end
		if GameCore.Idem:Seen(player, name.."_fn", payload and payload.rid) then
			_bump(GameCore.Metrics.Rejects, name.."_fn"); _hotUpdate(name.."_fn", false, true)
			GameCore.AC.Report(player, name, method, "replay", "idem_seen", 1)
			return nil
		end

		local fn = schema[method]; if typeof(fn) ~= "function" then return nil end
		_bump(GameCore.Metrics.Hits, name.."_fn"); _hotUpdate(name.."_fn", true, false)

		local ok, res = _time(name.."_fn", function() return fn(player, payload) end)
		if not ok then
			warn(("[GameCore:%s_fn] %s"):format(name, tostring(res)))
			_recordErr(player.UserId, name.."_fn"); _bump(GameCore.Metrics.Rejects, name.."_fn"); _hotUpdate(name.."_fn", false, true)
			return nil
		end
		return res
	end
	return {
		InvokeClient = function(_, plr, method, payload)
			local ok, res = pcall(function() return rf:InvokeClient(plr, method, payload) end)
			if ok then return res end
			warn(("[GameCore:%s_fn] InvokeClient error: %s"):format(name, tostring(res)))
			return nil
		end
	}
end

-- AC-wrapped binders
bindRoute = function(name, schema)
	local wrapped = {}
	for method, fn in pairs(schema) do
		wrapped[method] = function(player, payload)
			local svcObj = GameCore._services[name]
			local ok, why = _acNetGuard("evt", name, svcObj, player, method, payload or {})
			if not ok then return false, "blocked:"..tostring(why) end
			return fn(player, payload)
		end
	end
	return _baseBindRoute(name, wrapped)
end

bindFunction = function(name, schema)
	local wrapped = {}
	for method, fn in pairs(schema) do
		wrapped[method] = function(player, payload)
			local svcObj = GameCore._services[name]
			local ok, why = _acNetGuard("fn", name, svcObj, player, method, payload or {})
			if not ok then return nil end
			return fn(player, payload)
		end
	end
	return _baseBindFunction(name, wrapped)
end

----------------------------------------------------------------
-- Client helpers (events + functions)
----------------------------------------------------------------
if not IS_SERVER then
	function GameCore.On(routeName, cb)
		local r = ensureRemote(routeName)
		GameCore._clientSignals[routeName] = GameCore._clientSignals[routeName] or {}
		local conn = r.OnClientEvent:Connect(function(method, payload)
			if typeof(method) == "string" then cb(method, payload) end
		end)
		table.insert(GameCore._clientSignals[routeName], conn)
		return conn
	end
	
	function GameCore.Off(routeName)
		if GameCore._clientSignals[routeName] then
			for _,conn in ipairs(GameCore._clientSignals[routeName]) do
				if typeof(conn) == "RBXScriptConnection" then
					conn:Disconnect()
				end
			end
			GameCore._clientSignals[routeName] = nil
		end
	end

	function GameCore.Fire(routeName, method, payload)
		local r = ensureRemote(routeName); r:FireServer(method, payload)
	end
end

function GameCore.Invoke(routeName, method, payload)
	local rf = ensureFunction(routeName); return rf:InvokeServer(method, payload)
end
function GameCore.Bind(routeName, handler)
	local rf = ensureFunction(routeName)
	rf.OnClientInvoke = function(method, payload)
		if typeof(method) == "string" then return handler(method, payload) end
		return nil
	end
end

-- Safe invoke (Promise/Async aware)
function GameCore.InvokeSafe(routeName, method, payload, seconds)
	local rf = ensureFunction(routeName)
	if not PromiseMod then
		local ok, res = pcall(function() return rf:InvokeServer(method, payload) end)
		return ok and res or nil
	end
	local pr = PromiseMod.try(function()
		return rf:InvokeServer(method, payload)
	end)
	if Async and Async.withTimeout then
		pr = Async.withTimeout(pr, seconds or 5)
	end
	return pr:await()
end

-- ========== Lifecycle ==========
function GameCore.Use(sys) table.insert(GameCore._systems, sys) end
local function callAll(list, method)
	for _,m in list do
		local fn = rawget(m, method)
		if type(fn) == "function" then
			if method == "Init" then safe(function() fn(m, GameCore) end)
			else task.spawn(function() safe(function() fn(m, GameCore) end) end) end
		end
	end
end

GameCore.Sessions = {}
Players.PlayerAdded:Connect(function(p) GameCore.Sessions[p.UserId] = {joined=now(), data=nil} end)
Players.PlayerRemoving:Connect(function(p)
	GameCore.Sessions[p.UserId] = nil
	GameCore.AC.Move:End(p)
end)

GameCore.Health = { Alive=true, LastBeat=now() }
RunService.Heartbeat:Connect(function() GameCore.Health.LastBeat = now() end)

function GameCore.Ready() return GameCore._ready end
GameCore.Hooks = { Shutdown = {} }
function GameCore.OnShutdown(fn) table.insert(GameCore.Hooks.Shutdown, fn) end
if IS_SERVER then
	game:BindToClose(function()
		for _,fn in ipairs(GameCore.Hooks.Shutdown) do pcall(fn) end
	end)
end

local function topoSort(objs)
	local g, indeg = {}, {}
	for _,o in objs do
		local name = o.Name or tostring(o); g[name] = g[name] or {}
		for _,d in ipairs(o.DependsOn or {}) do g[d] = g[d] or {}; indeg[name] = (indeg[name] or 0) + 1 end
	end
	local q, out = {}, {}
	for n,_ in pairs(g) do if (indeg[n] or 0)==0 then table.insert(q,n) end end
	while #q>0 do
		local n = table.remove(q,1); table.insert(out,n)
		for m,_ in pairs(g) do
			local obj; for _,o in objs do if (o.Name or tostring(o))==m then obj=o end end
			if obj and table.find(obj.DependsOn or {}, n) then indeg[m]-=1; if indeg[m]==0 then table.insert(q,m) end end
		end
	end
	local map = {}; for _,o in objs do map[o.Name or tostring(o)] = o end
	local sorted = {}; for _,n in ipairs(out) do if map[n] then table.insert(sorted, map[n]) end end
	return sorted
end

local function childrenOf(inst)
	if not inst then return {} end
	local out = {}
	for _,it in ipairs(inst:GetDescendants()) do
		if it:IsA("ModuleScript") then table.insert(out, it) end
	end
	return out
end
local function requireAll(mods)
	local out = {}
	for _,m in mods do
		local ok, obj = safe(function() return require(m) end)
		if ok and type(obj)=="table" then table.insert(out, obj) end
	end
	return out
end

function GameCore.Init() callAll(GameCore._systems, "Init") end
function GameCore.Start()
	if GameCore._started then return end
	GameCore._started = true
	callAll(GameCore._systems, "Start")
	GameCore._ready = true
end

function GameCore.Auto()
	local roots = GameCore.Config.Roots or {}

	-- Server: Services
	if IS_SERVER and roots.Services then
		local mods = childrenOf(roots.Services)
		local services = requireAll(mods)

		for _, svc in services do
			local name = svc.Name or ("Service_" .. tostring(svc))
			GameCore._services[name] = svc
			if type(svc.Routes) == "table" then svc.Net = bindRoute(name, svc.Routes) else ensureRemote(name) end
			if type(svc.Functions) == "table" then svc.Fn = bindFunction(name, svc.Functions) else ensureFunction(name) end
		end

		services = topoSort(services)
		callAll(services, "Init")
		callAll(services, "Start")
	end

	-- Client: Controllers
	if not IS_SERVER and roots.Controllers then
		local mods = childrenOf(roots.Controllers)
		local controllers = requireAll(mods)

		for _, ctl in controllers do
			local name = ctl.Name or ("Controller_" .. tostring(ctl))
			GameCore._controllers[name] = ctl

			if type(ctl.AutoRoutes) == "table" then
				for _, route in ipairs(ctl.AutoRoutes) do
					GameCore.On(route, function(method, payload)
						if type(ctl.OnRoute) == "function" then ctl:OnRoute(route, method, payload) end
					end)
				end
			end
			if type(ctl.Functions) == "table" then
				GameCore.Bind(name, function(method, payload)
					local fn = ctl.Functions[method]
					if type(fn) == "function" then return fn(ctl, GameCore, payload) end
					return nil
				end)
			end
		end

		controllers = topoSort(controllers)
		callAll(controllers, "Init")
		callAll(controllers, "Start")
	end

	GameCore.Init()
	GameCore.Start()
end

-- ========== Tiny time helpers ==========
function GameCore.Debounce(key, ms)
	local k = "__db_"..key
	local t = cacheGet(k)
	local nowms = now()*1000
	if t and (nowms - t) < ms then return false end
	cacheSet(k, nowms, ms/1000 + 1)
	return true
end
function GameCore.Throttle(key, perSec)
	local sec = math.floor(now())
	local k = "__th_"..key
	local b = cacheGet(k) or { s = sec, n = 0 }
	if b.s ~= sec then b.s, b.n = sec, 0 end
	if b.n < perSec then b.n += 1; cacheSet(k, b, 2); return true end
	cacheSet(k, b, 2); return false
end

return GameCore]]></ProtectedString>
