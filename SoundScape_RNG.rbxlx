					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local GameCore = require(ReplicatedStorage.Main.GameCore)
local GetPlayerRegion = require(ReplicatedStorage.Main.Modules.GetPlayerRegion)

local ctl = {
	Name = "GameTextController",
	Config = {
		Version = "1.0.0",
		Format = "v{version}  |  {continent} ({code}{flag})  |  {serverShort}",
		Path = "Main/Bottom/GameText",
		ShowFlag = true,
		RefreshSeconds = 60,
		FallbackText = "Loading...",
		RetryAttempts = 3,
	},
}

local regionCache = nil
local lastUpdate = 0

local function getLabel()
	local pg = Players.LocalPlayer:WaitForChild("PlayerGui")
	local main = pg:WaitForChild("Main", 10)
	if not main then return nil end

	local node = main:FindFirstChild("Bottom") or main:WaitForChild("Bottom", 5)
	if not node then return nil end

	local label = node:FindFirstChild("GameText") or node:WaitForChild("GameText", 5)
	return label and label:IsA("TextLabel") and label or nil
end

local function flagFromCode(code)
	if not code or #code < 2 then return "" end
	code = string.upper(code)

	local function ri(ch)
		local o = string.byte(ch) - string.byte("A")
		if o < 0 or o > 25 then return "" end
		return utf8.char(0x1F1E6 + o)
	end

	return ri(code:sub(1,1)) .. ri(code:sub(2,2))
end

local function shortJobId(id)
	if not id or #id == 0 or id == "00000000-0000-0000-0000-000000000000" then
		return "LOCAL"
	end
	return string.split(id, "-")[1]
end

local function getCachedRegion()
	local now = tick()
	if regionCache and (now - lastUpdate) < 300 then
		return regionCache.continent, regionCache.code
	end

	local continent, code = GetPlayerRegion.fromPlayer(Players.LocalPlayer)
	regionCache = {continent = continent, code = code}
	lastUpdate = now
	return continent, code
end

local function renderText(cfg)
	local continent, code = getCachedRegion()
	local flag = cfg.ShowFlag and flagFromCode(code) or ""
	local jobId = game.JobId

	local subs = {
		version = cfg.Version,
		continent = continent or "Unknown",
		code = (code and #code > 0) and code or "??",
		flag = (flag ~= "" and (" "..flag)) or "",
		serverId = (jobId and #jobId > 0) and jobId or "LOCAL",
		serverShort = shortJobId(jobId),
	}

	local out = cfg.Format
	for k, v in pairs(subs) do
		out = out:gsub("{"..k.."}", tostring(v))
	end

	return out
end

function ctl:Init()
	self._cfg = table.clone(self.Config)
	self._running = false
end

function ctl:Start()
	if self._running then return end
	self._running = true

	local label = getLabel()
	if not label then 
		GameCore.Log:warn("GameTextController: Label not found")
		return 
	end

	local function update()
		local success, result = pcall(renderText, self._cfg)
		label.Text = success and result or self._cfg.FallbackText
	end

	update()

	task.spawn(function()
		local attempts = 0
		while self._running and task.wait(self._cfg.RefreshSeconds) do
			if not label.Parent then
				label = getLabel()
				if not label then
					attempts = attempts + 1
					if attempts >= self._cfg.RetryAttempts then
						GameCore.Log:error("GameTextController: Max retry attempts reached")
						break
					end
					continue
				end
				attempts = 0
			end
			update()
		end
	end)
end

function ctl:Stop()
	self._running = false
end

function ctl:GetCurrentText()
	return renderText(self._cfg)
end

function ctl:UpdateConfig(newConfig)
	for k, v in pairs(newConfig) do
		if self._cfg[k] ~= nil then
			self._cfg[k] = v
		end
	end
end

return ctl]]></ProtectedString>
