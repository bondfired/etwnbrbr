						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local DataStoreService = game:GetService("DataStoreService")
local MemoryStoreService = game:GetService("MemoryStoreService")
local RunService = game:GetService("RunService")

local KVStore = {}
KVStore.__index = KVStore

local function sleep(sec) task.wait(sec) end

local function backoff(attempt) -- 0.2s → ~1.6s
	return math.min(0.2 * (2 ^ (attempt - 1)), 1.6)
end

local StudioMock = {}
StudioMock.__index = StudioMock

function StudioMock.new()
	return setmetatable({ _t = {} }, StudioMock)
end

function StudioMock:GetAsync(k) return self._t[k] end
function StudioMock:SetAsync(k, v) self._t[k] = v end
function StudioMock:UpdateAsync(k, fn)
	local old = self._t[k]
	local new = fn(old)
	self._t[k] = new
	return new
end

local function newLock(lockName, ttl)
	local mem = MemoryStoreService:GetSortedMap(lockName)
	return {
		acquire = function(key, holder, expiresIn)
			local ok = pcall(function()
				mem:SetAsync(key, holder, expiresIn or ttl)
			end)
			return ok == true
		end,
		release = function(key)
			pcall(function() mem:RemoveAsync(key) end)
		end,
		renew = function(key, holder, expiresIn)
			pcall(function() mem:SetAsync(key, holder, expiresIn or ttl) end)
		end
	}
end

function KVStore.new(storeName: string, lockName: string)
	local ds = RunService:IsStudio() and StudioMock.new() or DataStoreService:GetDataStore(storeName)
	local lock = newLock(lockName or (storeName.."_locks"), 90)
	return setmetatable({ _ds = ds, _lock = lock }, KVStore)
end

function KVStore:get(key: string, tries: number?)
	tries = tries or 6
	for i = 1, tries do
		local ok, result = pcall(function()
			return self._ds:GetAsync(key)
		end)
		if ok then return result end
		sleep(backoff(i))
	end
	return nil
end

function KVStore:set(key: string, value: any, tries: number?)
	tries = tries or 6
	for i = 1, tries do
		local ok = pcall(function()
			self._ds:SetAsync(key, value)
		end)
		if ok then return true end
		sleep(backoff(i))
	end
	return false
end

function KVStore:update(key: string, updater: (any)->any, tries: number?)
	tries = tries or 6
	for i = 1, tries do
		local ok, res = pcall(function()
			return self._ds:UpdateAsync(key, function(old)
				return updater(old)
			end)
		end)
		if ok then return res end
		sleep(backoff(i))
	end
	return nil
end

function KVStore:acquireLock(key: string, holder: string, ttl: number?)
	return self._lock.acquire(key, holder, ttl)
end

function KVStore:releaseLock(key: string)
	self._lock.release(key)
end

function KVStore:renewLock(key: string, holder: string, ttl: number?)
	self._lock.renew(key, holder, ttl)
end

return KVStore]]></ProtectedString>
