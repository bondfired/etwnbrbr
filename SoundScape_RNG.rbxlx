						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[--!strict
-- Shime v1.1.0 (singleton-per-parent, safe reuse, destroy)
-- Original by RyanLua (Apache-2.0) — tweaked for GameCore integration

local TweenService = game:GetService("TweenService")

local Shime = {}
Shime.__index = Shime

local REGISTRY: { [GuiObject]: Shime } = setmetatable({}, { __mode = "k" })

local function findOrCreateFrame(parent: GuiObject): Frame
	local existing = parent:FindFirstChild("UIShimmer")
	if existing and existing:IsA("Frame") then
		existing.ZIndex = (parent.ZIndex or 1) + 1
		parent:GetPropertyChangedSignal("ZIndex"):Connect(function()
			if existing.Parent then
				existing.ZIndex = (parent.ZIndex or 1) + 1
			end
		end)
		return existing
	end

	local frame = Instance.new("Frame")
	frame.Name = "UIShimmer"
	frame.BackgroundColor3 = Color3.new(1,1,1)
	frame.BackgroundTransparency = 0
	frame.ClipsDescendants = true
	frame.Size = UDim2.fromScale(1,1)
	frame.AnchorPoint = Vector2.new(0.5,0.5)
	frame.Position = UDim2.fromScale(0.5,0.5)
	frame.BorderSizePixel = 0
	frame.Visible = false
	frame.ZIndex = (parent.ZIndex or 1) + 1
	frame.Parent = parent

	parent:GetPropertyChangedSignal("ZIndex"):Connect(function()
		if frame.Parent then
			frame.ZIndex = (parent.ZIndex or 1) + 1
		end
	end)

	local function syncCorner()
		local p = frame.Parent
		if not p then return end
		local parentCorner = p:FindFirstChildOfClass("UICorner")
		local mine = frame:FindFirstChildOfClass("UICorner") or Instance.new("UICorner")
		mine.Name = "Corner"
		mine.Parent = frame
		if parentCorner then mine.CornerRadius = parentCorner.CornerRadius end
	end
	syncCorner()
	frame.AncestryChanged:Connect(function() task.defer(syncCorner) end)

	local function syncPadding()
		local p = frame.Parent; if not p then return end
		local pad = p:FindFirstChildOfClass("UIPadding")
		if not pad then
			frame.Size = UDim2.fromScale(1,1); frame.Position = UDim2.fromScale(0.5,0.5); return
		end
		local wS = pad.PaddingLeft.Scale + pad.PaddingRight.Scale
		local hS = pad.PaddingTop.Scale  + pad.PaddingBottom.Scale
		local wO = pad.PaddingLeft.Offset + pad.PaddingRight.Offset
		local hO = pad.PaddingTop.Offset  + pad.PaddingBottom.Offset
		local wDiff = pad.PaddingLeft.Offset - pad.PaddingRight.Offset
		local hDiff = pad.PaddingTop.Offset  - pad.PaddingBottom.Offset
		local wSize = (1 - wS) ~= 0 and (1/(1 - wS)) or 1
		local hSize = (1 - hS) ~= 0 and (1/(1 - hS)) or 1
		frame.Size = UDim2.new(wSize, wO, hSize, hO)
		frame.Position = UDim2.new(0.5, -wDiff/2, 0.5, -hDiff/2)
	end
	syncPadding()
	frame.AncestryChanged:Connect(function() task.defer(syncPadding) end)
	task.defer(function()
		local p = frame.Parent; if not p then return end
		local pad = p:FindFirstChildOfClass("UIPadding"); if not pad then return end
		pad:GetPropertyChangedSignal("PaddingLeft"):Connect(syncPadding)
		pad:GetPropertyChangedSignal("PaddingRight"):Connect(syncPadding)
		pad:GetPropertyChangedSignal("PaddingTop"):Connect(syncPadding)
		pad:GetPropertyChangedSignal("PaddingBottom"):Connect(syncPadding)
	end)

	local g = Instance.new("UIGradient")
	g.Rotation = 15
	g.Color = ColorSequence.new(Color3.new(1,1,1))
	g.Transparency = NumberSequence.new{
		NumberSequenceKeypoint.new(0, 1),
		NumberSequenceKeypoint.new(0.15, 1),
		NumberSequenceKeypoint.new(0.5, 0.55),
		NumberSequenceKeypoint.new(0.85, 1),
		NumberSequenceKeypoint.new(1, 1),
	}
	g.Offset = Vector2.new(-1, 0)
	g.Parent = frame

	return frame
end

local function stopExisting(parent: GuiObject)
	local prev = REGISTRY[parent]
	if not prev then return end
	pcall(function()
		if prev._tween then prev._tween:Cancel() end
		if prev._frame then prev._frame.Visible = false end
	end)
	REGISTRY[parent] = nil
end

function Shime.new(
	parent: GuiObject,
	time: number?,
	style: Enum.EasingStyle?,
	direction: Enum.EasingDirection?,
	repeatCount: number?,
	reverses: boolean?,
	delayTime: number?
)
	assert(typeof(parent)=="Instance" and parent:IsA("GuiObject"), "Shime.new: parent must be GuiObject")

	stopExisting(parent)

	local self = setmetatable({}, Shime)

	local EASING_TIME      = time or 1
	local EASING_STYLE     = style or Enum.EasingStyle.Linear
	local EASING_DIRECTION = direction or Enum.EasingDirection.InOut
	local REPEAT_COUNT     = (repeatCount == nil) and -1 or repeatCount
	local REVERSES         = reverses or false
	local DELAY_TIME       = delayTime or 0

	local frame = findOrCreateFrame(parent)
	local gradient = frame:FindFirstChildOfClass("UIGradient") :: UIGradient
	gradient.Offset = Vector2.new(-1, 0)

	self._frame = frame
	self._gradient = gradient
	self._tween = TweenService:Create(
		gradient,
		TweenInfo.new(EASING_TIME, EASING_STYLE, EASING_DIRECTION, REPEAT_COUNT, REVERSES, DELAY_TIME),
		{ Offset = Vector2.new(1, 0) }
	)
	self.PlaybackState = Enum.PlaybackState.Paused

	self._conn = self._tween.Completed:Connect(function()
		self._frame.Visible = false
		self.PlaybackState = Enum.PlaybackState.Completed
	end)

	REGISTRY[parent] = self
	return self
end

function Shime:GetFrame(): Frame return self._frame end
function Shime:GetGradient(): UIGradient return self._gradient end

function Shime:Play()
	self.PlaybackState = Enum.PlaybackState.Begin
	if self._frame then self._frame.Visible = true end
	if self._gradient then self._gradient.Offset = Vector2.new(-1, 0) end
	if self._tween then self._tween:Play() end
	self.PlaybackState = Enum.PlaybackState.Playing
end

function Shime:Pause()
	if self.PlaybackState == Enum.PlaybackState.Playing and self._tween then
		self._tween:Pause()
		self.PlaybackState = Enum.PlaybackState.Paused
	end
end

function Shime:Cancel()
	if self._tween then self._tween:Cancel() end
	if self._frame then self._frame.Visible = false end
	self.PlaybackState = Enum.PlaybackState.Cancelled
end

Shime.Stop = Shime.Cancel

function Shime:Destroy()
	self:Cancel()
	if self._conn then self._conn:Disconnect() end
	local parent = self._frame and self._frame.Parent
	if parent and REGISTRY[parent] == self then
		REGISTRY[parent] = nil
	end
end

function Shime.PlayOnce(parent: GuiObject, time: number?)
	local s = Shime.new(parent, time or 0.8, Enum.EasingStyle.Exponential, Enum.EasingDirection.InOut, 0, false, 0)
	s:Play()
	return s
end

return Shime
]]></ProtectedString>
