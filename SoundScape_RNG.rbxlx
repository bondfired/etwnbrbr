					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[-- Require from BOTH client & server. On client it registers the callback; on server it returns a readonly table.
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

local Postie = require(script:WaitForChild("Postie"))

if RunService:IsClient() then
	Postie.SetCallback("RequestPing", function(guid: string)
		return guid
	end)
	return nil
end

-- Server
local UPDATE_FREQUENCY = 3 -- seconds
local PingTimes: {[Player]: number} = {}

local function pingPlayer(plr: Player)
	local guid = HttpService:GenerateGUID(false)
	local t0 = os.clock()
	local ok, returned = Postie.InvokeClient("RequestPing", plr, 3, guid)
	if ok and returned == guid then
		PingTimes[plr] = os.clock() - t0
	end
end

task.spawn(function()
	while task.wait(UPDATE_FREQUENCY) do
		for _, plr in ipairs(Players:GetPlayers()) do
			task.spawn(pingPlayer, plr)
		end
	end
end)

Players.PlayerAdded:Connect(function(plr)
	task.delay(1, pingPlayer, plr)
end)

Players.PlayerRemoving:Connect(function(plr)
	PingTimes[plr] = nil
end)

return setmetatable({}, {
	__index = function(_, key)
		return (typeof(key) == "Instance" and key:IsA("Player")) and (PingTimes[key] or 0.075) or nil
	end,
	__newindex = function() warn("Cannot set PingTime manually") end,
})]]></ProtectedString>
						<string name="ScriptGuid">{8E017427-635B-4CA2-AAFB-D2DA93B6F934}</string>
