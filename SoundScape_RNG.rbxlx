						<string name="ScriptGuid">{1AC8ED43-FE4E-4525-98C2-3745A6FC4FA0}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">Codes</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">5fb753d16b0c0fab08e67a16000045ea</UniqueId>
					</Properties>
				</Item>
			</Item>
			<Item class="Folder" referent="RBXB83C35F5855245368F5FCDACAF400914">
				<Properties>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
					<string name="Name">UI</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
					<UniqueId name="UniqueId">07ebdd09a73c51df08da6b9c0000658e</UniqueId>
				</Properties>
				<Item class="ModuleScript" referent="RBX52F584B29BD64045AB1A655B8587CF42">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[-- Made By Akira
----------------------------------------------------------------------------------
local TweenService = game:GetService("TweenService")
----------------------------------------------------------------------------------
local FrameAnimator = {}
----------------------------------------------------------------------------------
local DEFAULT_SETTINGS = {
	openDuration = 0.5,
	closeDuration = 0.4,
	openEasingStyle = Enum.EasingStyle.Back,
	closeEasingStyle = Enum.EasingStyle.Quad,
	openEasingDirection = Enum.EasingDirection.Out,
	closeEasingDirection = Enum.EasingDirection.InOut,
	centerPosition = true,
	fadeTransparency = true,
	overshoot = true,
	overshootMultiplier = 1.2,
}
----------------------------------------------------------------------------------
local activeTweens = {}

local function cleanupTweens(frame)
	if activeTweens[frame] then
		for _, tween in pairs(activeTweens[frame]) do
			if tween.PlaybackState ~= Enum.PlaybackState.Completed then
				tween:Cancel()
			end
		end
		activeTweens[frame] = nil
	end
end

local function mergeSettings(customSettings)
	local settings = table.clone(DEFAULT_SETTINGS)
	if customSettings then
		for key, value in pairs(customSettings) do
			settings[key] = value
		end
	end
	return settings
end

local function storeOriginalProperties(frame)
	if not frame:GetAttribute("OriginalSize") then
		frame:SetAttribute("OriginalSize", frame.Size)
	end
	if not frame:GetAttribute("OriginalPosition") then
		frame:SetAttribute("OriginalPosition", frame.Position)
	end
	if not frame:GetAttribute("OriginalAnchorPoint") then
		frame:SetAttribute("OriginalAnchorPoint", frame.AnchorPoint)
	end
	if not frame:GetAttribute("OriginalTransparency") then
		frame:SetAttribute("OriginalTransparency", frame.BackgroundTransparency)
	end
end

local function getBaseSize(btn: GuiButton): UDim2
	return btn:GetAttribute("BaseSize") or btn.Size
end
local function setBaseSize(btn: GuiButton)
	if not btn:GetAttribute("BaseSize") then
		btn:SetAttribute("BaseSize", btn.Size)
	end
end

local function findCloseButton(frame: Frame): GuiButton?
	local main = frame:FindFirstChild("Main")
	if main then
		for _,n in ipairs({"CloseButton","Close","X"}) do
			local b = main:FindFirstChild(n)
			if b and b:IsA("GuiButton") then return b end
		end
	end
	for _,desc in ipairs(frame:GetDescendants()) do
		if desc:IsA("GuiButton") and (desc.Name == "CloseButton" or desc.Name == "Close" or desc.Name == "X") then
			return desc
		end
	end
	return nil
end
----------------------------------------------------------------------------------
function FrameAnimator.openFrame(frame, customSettings)
	if not frame then return end

	cleanupTweens(frame)
	local settings = mergeSettings(customSettings)
	storeOriginalProperties(frame)

	frame.Size = UDim2.new(0, 0, 0, 0)
	frame.Visible = true

	if settings.centerPosition then
		frame.AnchorPoint = Vector2.new(0.5, 0.5)
		frame.Position = UDim2.new(0.5, 0, 0.5, 0)
	end

	if settings.fadeTransparency then
		frame.BackgroundTransparency = 1
	end

	local targetSize = frame:GetAttribute("OriginalSize")
	local tweenProperties = {Size = targetSize}

	if settings.fadeTransparency then
		tweenProperties.BackgroundTransparency = frame:GetAttribute("OriginalTransparency")
	end

	local mainTween = TweenService:Create(frame, 
		TweenInfo.new(
			settings.openDuration,
			settings.openEasingStyle,
			settings.openEasingDirection
		),
		tweenProperties
	)

	activeTweens[frame] = {mainTween}

	if settings.overshoot and settings.openEasingStyle == Enum.EasingStyle.Back then
		local overshootTween = TweenService:Create(frame, 
			TweenInfo.new(
				settings.openDuration * settings.overshootMultiplier,
				settings.openEasingStyle,
				settings.openEasingDirection
			),
			{Size = targetSize}
		)
		table.insert(activeTweens[frame], overshootTween)
		overshootTween:Play()
	end

	mainTween.Completed:Connect(function()
		cleanupTweens(frame)
	end)

	mainTween:Play()
	return mainTween
end
----------------------------------------------------------------------------------
function FrameAnimator.openModal(frame: Frame, backdrop: Frame?, customSettings: {}?)
	local settings = mergeSettings(customSettings)
	storeOriginalProperties(frame)
	cleanupTweens(frame)

	if backdrop then
		backdrop.Visible = true
		backdrop.BackgroundTransparency = 1
		local bt = TweenService:Create(backdrop, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ BackgroundTransparency = 0.35 })
		bt:Play()
		activeTweens[frame] = activeTweens[frame] or {}
		table.insert(activeTweens[frame], bt)
	end

	local scale = frame:FindFirstChildOfClass("UIScale") or Instance.new("UIScale")
	scale.Scale = 0.8
	scale.Parent = frame

	frame.Visible = true
	if settings.centerPosition then
		frame.AnchorPoint = Vector2.new(0.5, 0.5)
		frame.Position = UDim2.fromScale(0.5, 0.5)
	end

	if settings.fadeTransparency then
		frame.BackgroundTransparency = 1
	end

	local props = {}
	if settings.fadeTransparency then
		props.BackgroundTransparency = frame:GetAttribute("OriginalTransparency") or 0
	end

	local fadeTween = TweenService:Create(frame,
		TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		props
	)

	local popTween = TweenService:Create(scale,
		TweenInfo.new(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
		{ Scale = 1 }
	)

	activeTweens[frame] = activeTweens[frame] or {}
	table.insert(activeTweens[frame], fadeTween)
	table.insert(activeTweens[frame], popTween)

	fadeTween:Play()
	popTween:Play()

	return popTween
end
----------------------------------------------------------------------------------
function FrameAnimator.closeFrame(frame, customSettings)
	if not frame then return end

	cleanupTweens(frame)
	local settings = mergeSettings(customSettings)

	local tweenProperties = {Size = UDim2.new(0, 0, 0, 0)}

	if settings.fadeTransparency then
		tweenProperties.BackgroundTransparency = 1
	end

	local closeTween = TweenService:Create(frame,
		TweenInfo.new(
			settings.closeDuration,
			settings.closeEasingStyle,
			settings.closeEasingDirection
		),
		tweenProperties
	)

	activeTweens[frame] = {closeTween}

	closeTween.Completed:Connect(function()
		frame.Visible = false
		cleanupTweens(frame)
	end)

	closeTween:Play()
	return closeTween
end
----------------------------------------------------------------------------------
function FrameAnimator.closeModal(frame: Frame, backdrop: Frame?, customSettings: {}?)
	local settings = mergeSettings(customSettings)
	cleanupTweens(frame)

	local scale = frame:FindFirstChildOfClass("UIScale")
	if not scale then
		scale = Instance.new("UIScale"); scale.Scale = 1; scale.Parent = frame
	end

	local liftTween = TweenService:Create(frame,
		TweenInfo.new(0.06, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ Position = frame.Position - UDim2.fromOffset(0, 6) }
	)
	local shrinkTween = TweenService:Create(scale,
		TweenInfo.new(settings.closeDuration or 0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
		{ Scale = 0.86 }
	)
	local fadeTween = TweenService:Create(frame,
		TweenInfo.new(settings.closeDuration or 0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
		{ BackgroundTransparency = 1 }
	)

	liftTween:Play()
	task.wait(0.05)
	shrinkTween:Play()
	fadeTween:Play()

	if backdrop then
		TweenService:Create(backdrop, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
			{ BackgroundTransparency = 1 }):Play()
	end

	shrinkTween.Completed:Connect(function()
		frame.Visible = false
		if backdrop then backdrop.Visible = false end
		FrameAnimator.restoreFrame(frame)
		frame.Visible = false
	end)

	return shrinkTween
end
----------------------------------------------------------------------------------
function FrameAnimator.wireCloseButton(btn: GuiButton, onClick: () -> ())
	if not btn then return end
	setBaseSize(btn)
	btn.Active = true
	btn.AutoButtonColor = true

	local hoverTween, leaveTween, pressTween, releaseTween

	local function kill(t) if t and t.PlaybackState ~= Enum.PlaybackState.Completed then t:Cancel() end end
	local base = getBaseSize(btn)

	btn.MouseEnter:Connect(function()
		kill(leaveTween)
		kill(hoverTween)
		hoverTween = TweenService:Create(btn, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ Rotation = 8, Size = base + UDim2.fromOffset(6,6) })
		hoverTween:Play()
	end)

	local function backToBase()
		kill(hoverTween)
		kill(leaveTween)
		leaveTween = TweenService:Create(btn, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ Rotation = 0, Size = base })
		leaveTween:Play()
	end

	btn.MouseLeave:Connect(backToBase)

	btn.MouseButton1Down:Connect(function()
		kill(pressTween)
		pressTween = TweenService:Create(btn, TweenInfo.new(0.06, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ Size = base - UDim2.fromOffset(4,4) })
		pressTween:Play()
	end)

	btn.MouseButton1Up:Connect(function()
		kill(releaseTween)
		releaseTween = TweenService:Create(btn, TweenInfo.new(0.08, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
			{ Size = base })
		releaseTween:Play()
	end)

	btn.TouchTap:Connect(function() if onClick then onClick() end end)
	btn.MouseButton1Click:Connect(function() if onClick then onClick() end end)
end
----------------------------------------------------------------------------------
function FrameAnimator.bindClose(frame: Frame, onClose: () -> (), backdrop: Frame?)
	local btn = findCloseButton(frame)
	if btn then
		FrameAnimator.wireCloseButton(btn, onClose)
	end
	if backdrop then
		backdrop.Active = true
		backdrop.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				onClose()
			end
		end)
	end
	return btn
end
----------------------------------------------------------------------------------
function FrameAnimator.restoreFrame(frame)
	if not frame then return end

	cleanupTweens(frame)

	local originalSize = frame:GetAttribute("OriginalSize")
	local originalPosition = frame:GetAttribute("OriginalPosition")
	local originalAnchorPoint = frame:GetAttribute("OriginalAnchorPoint")
	local originalTransparency = frame:GetAttribute("OriginalTransparency")

	if originalSize then frame.Size = originalSize end
	if originalPosition then frame.Position = originalPosition end
	if originalAnchorPoint then frame.AnchorPoint = originalAnchorPoint end
	if originalTransparency then frame.BackgroundTransparency = originalTransparency end

	frame.Visible = true
end
----------------------------------------------------------------------------------
function FrameAnimator.isAnimating(frame)
	return activeTweens[frame] ~= nil
end
----------------------------------------------------------------------------------
function FrameAnimator.stopAnimation(frame)
	cleanupTweens(frame)
end
----------------------------------------------------------------------------------
return FrameAnimator
----------------------------------------------------------------------------------]]></ProtectedString>
						<string name="ScriptGuid">{18AA5278-52D7-4BC1-A471-8639B769958F}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">3897522525105913079cc2b500007c71</UniqueId>
						<string name="Name">FrameAnimator</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">07ebdd09a73c51df08da6b9c0000658f</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="RBX1AF512D14A574247A6327106F4F2F3A2">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local TweenService = game:GetService("TweenService")

local M = {}

local function ensureScale(gui: GuiObject)
	local s = gui:FindFirstChildOfClass("UIScale")
	if not s then s = Instance.new("UIScale", gui) end
	return s
end

local function kill(t) if t and t.PlaybackState == Enum.PlaybackState.Playing then t:Cancel() end end

local function spinGradient(grad: UIGradient, seconds: number)
	if not grad then return end
	task.spawn(function()
		while grad.Parent do
			grad.Rotation = 0
			local tw = TweenService:Create(grad, TweenInfo.new(seconds, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut), {Rotation = 360})
			tw:Play(); tw.Completed:Wait()
		end
	end)
end

local function bobIcon(icon: GuiObject)
	if not icon then return end
	task.spawn(function()
		local base = icon.Position
		while icon.Parent do
			local up   = TweenService:Create(icon, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Position = base - UDim2.fromOffset(0, 4)})
			local down = TweenService:Create(icon, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.In),  {Position = base})
			up:Play();   up.Completed:Wait()
			down:Play(); down.Completed:Wait()
		end
	end)
end

function M.attach(folder: Instance)

	if not folder or not folder:IsA("Frame") then return end
	local hit = folder:FindFirstChild("TextButton")
	if not hit or not hit:IsA("TextButton") then return end
	local outerGrad  = folder:FindFirstChildOfClass("UIGradient")
	local outerStroke= folder:FindFirstChildOfClass("UIStroke")
	local main       = folder:FindFirstChild("Main")
	local innerStroke= main and main:FindFirstChildOfClass("UIStroke") or nil
	local icon       = main and main:FindFirstChild("Icon") or nil

	local scaleTarget = ensureScale(folder)
	local tHover, tLeave, tDown, tUp
	local baseThickness = (outerStroke and outerStroke.Thickness) or 2
	local innerThickness= (innerStroke and innerStroke.Thickness) or 2

	spinGradient(outerGrad, 3.2)
	bobIcon(icon)

	hit.AutoButtonColor = false

	hit.MouseEnter:Connect(function()
		kill(tLeave); kill(tHover)
		tHover = TweenService:Create(scaleTarget, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 1.06})
		tHover:Play()
		if outerStroke then
			TweenService:Create(outerStroke, TweenInfo.new(0.12), {Thickness = baseThickness + 1}):Play()
		end
		if innerStroke then
			TweenService:Create(innerStroke, TweenInfo.new(0.12), {Thickness = innerThickness + 1}):Play()
		end
	end)

	local function leave()
		kill(tHover); kill(tLeave)
		tLeave = TweenService:Create(scaleTarget, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 1})
		tLeave:Play()
		if outerStroke then TweenService:Create(outerStroke, TweenInfo.new(0.12), {Thickness = baseThickness}):Play() end
		if innerStroke then TweenService:Create(innerStroke, TweenInfo.new(0.12), {Thickness = innerThickness}):Play() end
	end
	hit.MouseLeave:Connect(leave)

	hit.MouseButton1Down:Connect(function()
		kill(tDown)
		tDown = TweenService:Create(scaleTarget, TweenInfo.new(0.06, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 0.96})
		tDown:Play()
	end)

	hit.MouseButton1Up:Connect(function()
		kill(tUp)
		tUp = TweenService:Create(scaleTarget, TweenInfo.new(0.10, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1.06})
		tUp:Play()
	end)

	folder:GetPropertyChangedSignal("Visible"):Connect(function()
		if not folder.Visible then
			scaleTarget.Scale = 1
			if outerStroke then outerStroke.Thickness = baseThickness end
			if innerStroke then innerStroke.Thickness = innerThickness end
		end
	end)
end

function M.attach2(folder: Instance)
	if not folder or not folder:IsA("Frame") then return end

	local hit  = folder:FindFirstChild("TextButton")
	if not hit or not hit:IsA("TextButton") then return end

	local main = folder:FindFirstChild("Main")

	local outerGrad   = folder:FindFirstChildOfClass("UIGradient") or (main and main:FindFirstChildOfClass("UIGradient"))
	local outerStroke = folder:FindFirstChildOfClass("UIStroke")   or (main and main:FindFirstChildOfClass("UIStroke"))

	local innerStroke = nil
	if main then
		local s = main:FindFirstChildOfClass("UIStroke")
		if s and s ~= outerStroke then innerStroke = s end
	end

	local icon = (main and (main:FindFirstChild("Icon") or main:FindFirstChild("Texture"))) or folder:FindFirstChild("Icon")

	local scaleTarget = ensureScale(folder)

	local tHover, tLeave, tDown, tUp
	local baseThickness  = (outerStroke and outerStroke.Thickness) or 2
	local innerThickness = (innerStroke and innerStroke.Thickness) or 2

	if outerGrad then spinGradient(outerGrad, 3.2) end
	if icon then bobIcon(icon) end

	hit.AutoButtonColor = false

	hit.MouseEnter:Connect(function()
		kill(tLeave); kill(tHover)
		tHover = TweenService:Create(scaleTarget, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 1.06})
		tHover:Play()
		if outerStroke then TweenService:Create(outerStroke, TweenInfo.new(0.12), {Thickness = baseThickness + 1}):Play() end
		if innerStroke then TweenService:Create(innerStroke, TweenInfo.new(0.12), {Thickness = innerThickness + 1}):Play() end
	end)

	local function leave()
		kill(tHover); kill(tLeave)
		tLeave = TweenService:Create(scaleTarget, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 1})
		tLeave:Play()
		if outerStroke then TweenService:Create(outerStroke, TweenInfo.new(0.12), {Thickness = baseThickness}):Play() end
		if innerStroke then TweenService:Create(innerStroke, TweenInfo.new(0.12), {Thickness = innerThickness}):Play() end
	end
	hit.MouseLeave:Connect(leave)

	hit.MouseButton1Down:Connect(function()
		kill(tDown)
		tDown = TweenService:Create(scaleTarget, TweenInfo.new(0.06, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = 0.96})
		tDown:Play()
	end)

	hit.MouseButton1Up:Connect(function()
		kill(tUp)
		tUp = TweenService:Create(scaleTarget, TweenInfo.new(0.10, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1.06})
		tUp:Play()
	end)

	folder:GetPropertyChangedSignal("Visible"):Connect(function()
		if not folder.Visible then
			scaleTarget.Scale = 1
			if outerStroke then outerStroke.Thickness = baseThickness end
			if innerStroke then innerStroke.Thickness = innerThickness end
		end
	end)
end

return M
