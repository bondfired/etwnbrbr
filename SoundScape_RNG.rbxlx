						<ProtectedString name="Source"><![CDATA[local RS = game:GetService("ReplicatedStorage")
local GameCore = require(RS.Main.GameCore)

local MarketClient = {}

function MarketClient.PromptProduct(key:string)
	GameCore.Fire("MarketService","PromptProduct",{ key = key, rid = os.clock() })
end

function MarketClient.PromptPass(key:string)
	GameCore.Fire("MarketService","PromptPass",{ key = key, rid = os.clock() })
end

function MarketClient.CheckPass(key:string)
	GameCore.Fire("MarketService","CheckPass",{ key = key, rid = os.clock() })
end

return MarketClient]]></ProtectedString>
