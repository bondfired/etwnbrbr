						<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local RS      = game:GetService("ReplicatedStorage")
local UIS     = game:GetService("UserInputService")

local GameCore = require(RS.Main.GameCore)

local C = { Name = "CodesController", AutoRoutes = { } }

local L  = Players.LocalPlayer
local PG = L:WaitForChild("PlayerGui")
local GUI = PG:WaitForChild("Main")

local CodesFrame = GUI.Menus:WaitForChild("CodesFrame")
local Main       = CodesFrame:WaitForChild("Main")
local SubmitBtn  = Main:WaitForChild("SubmitButton")
local TextBox    = Main:WaitForChild("TextBox")
local StatusText = Main:FindFirstChild("StatusText")

local lastExpireAt = 0
local lastMaxUses  = 0
local lastUsedCount= 0

local function setStatus(msg, color)
	if StatusText and StatusText:IsA("TextLabel") then
		StatusText.Text = msg
		if color then StatusText.TextColor3 = color end
	else
		warn("[CodesController]", msg)
	end
end

local function fmtRemaining(t)
	t = math.max(0, math.floor(t))
	local d = t // 86400; t = t % 86400
	local h = t // 3600;  t = t % 3600
	local m = t // 60;    t = t % 60
	if d > 0 then return string.format("%dd %dh %dm %ds", d, h, m, t)
	elseif h > 0 then return string.format("%dh %dm %ds", h, m, t)
	elseif m > 0 then return string.format("%dm %ds", m, t)
	else return string.format("%ds", t) end
end

task.spawn(function()
	while true do
		if lastExpireAt and lastExpireAt > 0 then
			local remain = lastExpireAt - os.time()
			if remain <= 0 then
				lastExpireAt = 0
			else
				if StatusText then
					local leftText = "Code active. "
					if lastMaxUses and lastMaxUses > 0 then
						local left = math.max(0, lastMaxUses - (lastUsedCount or 0))
						leftText ..= string.format("Global left: %d. ", left)
					end
					leftText ..= "Expires in "..fmtRemaining(remain).."."
					StatusText.Text = leftText
				end
			end
		end
		task.wait(1)
	end
end)

local function friendlyError(err)
	if err == "empty"      then return "Enter a code first."
	elseif err == "invalid"   then return "That code doesn’t exist."
	elseif err == "used"      then return "You’ve already redeemed this code."
	elseif err == "expired"   then return "That code has expired."
	elseif err == "maxed"     then return "That code hit the global limit."
	elseif err == "no_profile"or err == "ds_error" then return "Please try again in a moment."
	else return "Couldn’t redeem that code." end
end

local function redeem(code)
	if not code or code == "" then
		setStatus("Enter a code first.", Color3.fromRGB(230,80,80)); return
	end

	setStatus("Checking code...", Color3.fromRGB(255,255,255))
	local ok, res = pcall(function()
		return GameCore.Invoke("CodesService", "Redeem", { code = code })
	end)

	if not ok then
		setStatus("Couldn’t reach the server. Try again.", Color3.fromRGB(230,80,80))
		return
	end

	if type(res) == "table" and res.ok ~= nil then
		if res.ok then
			local p = res.data or {}
			lastExpireAt = tonumber(p.expireAt or 0) or 0
			lastMaxUses  = tonumber(p.maxUses or 0) or 0
			lastUsedCount= tonumber(p.usedCount or 0) or 0
			local leftMsg = ""
			if lastMaxUses > 0 then
				leftMsg = string.format(" Global left: %d.", math.max(0, lastMaxUses - lastUsedCount))
			end
			if lastExpireAt > 0 then
				setStatus("Code redeemed! Expires in "..fmtRemaining(lastExpireAt - os.time()).."."..leftMsg, Color3.fromRGB(60,200,80))
			else
				setStatus("Code redeemed!"..leftMsg, Color3.fromRGB(60,200,80))
			end
		else
			setStatus(friendlyError(res.err or res.reason), Color3.fromRGB(230,80,80))
		end
		return
	end

	if type(res) == "table" and (res.success ~= nil or res.reason or res.payload) then
		if res.success then
			local p = res.payload or {}
			lastExpireAt = tonumber(p.expireAt or 0) or 0
			lastMaxUses  = tonumber(p.maxUses or 0) or 0
			lastUsedCount= tonumber(p.usedCount or 0) or 0
			local leftMsg = ""
			if lastMaxUses > 0 then
				leftMsg = string.format(" Global left: %d.", math.max(0, lastMaxUses - lastUsedCount))
			end
			if lastExpireAt > 0 then
				setStatus("Code redeemed! Expires in "..fmtRemaining(lastExpireAt - os.time()).."."..leftMsg, Color3.fromRGB(60,200,80))
			else
				setStatus("Code redeemed!"..leftMsg, Color3.fromRGB(60,200,80))
			end
		else
			setStatus(friendlyError(res.reason), Color3.fromRGB(230,80,80))
		end
		return
	end

	if type(res) == "table" and res.ok == true then
		lastExpireAt = tonumber(res.expireAt or 0) or 0
		lastMaxUses  = tonumber(res.maxUses or 0) or 0
		lastUsedCount= tonumber(res.usedCount or 0) or 0
		local leftMsg = ""
		if lastMaxUses > 0 then
			leftMsg = string.format(" Global left: %d.", math.max(0, lastMaxUses - lastUsedCount))
		end
		if lastExpireAt > 0 then
			setStatus("Code redeemed! Expires in "..fmtRemaining(lastExpireAt - os.time()).."."..leftMsg, Color3.fromRGB(60,200,80))
		else
			setStatus("Code redeemed!"..leftMsg, Color3.fromRGB(60,200,80))
		end
		return
	end

	if type(res) == "table" and (res.expireAt or res.maxUses or res.usedCount) then
		lastExpireAt = tonumber(res.expireAt or 0) or 0
		lastMaxUses  = tonumber(res.maxUses or 0) or 0
		lastUsedCount= tonumber(res.usedCount or 0) or 0
		local leftMsg = ""
		if lastMaxUses > 0 then
			leftMsg = string.format(" Global left: %d.", math.max(0, lastMaxUses - lastUsedCount))
		end
		if lastExpireAt > 0 then
			setStatus("Code redeemed! Expires in "..fmtRemaining(lastExpireAt - os.time()).."."..leftMsg, Color3.fromRGB(60,200,80))
		else
			setStatus("Code redeemed!"..leftMsg, Color3.fromRGB(60,200,80))
		end
		return
	end

	if type(res) == "string" then
		setStatus(friendlyError(res), Color3.fromRGB(230,80,80))
	else
		setStatus("Couldn’t redeem that code.", Color3.fromRGB(230,80,80))
	end
end

local function submit()
	local code = (TextBox.Text or ""):gsub("^%s+",""):gsub("%s+$","")
	redeem(code)
end

function C:Start()
	SubmitBtn.MouseButton1Click:Connect(submit)
	TextBox.FocusLost:Connect(function(enterPressed)
		if enterPressed then submit() end
	end)
end

return C
]]></ProtectedString>
