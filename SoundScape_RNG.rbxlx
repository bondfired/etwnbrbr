						<string name="Name">RNGController</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">4d8bdd6f91b989d008d8cced000051c2</UniqueId>
